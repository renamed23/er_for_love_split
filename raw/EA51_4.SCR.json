    "offset": 2009,
    "index": 65,
    "value": [
      "u16:27",
      "u8:0",
      "u8:0",
      "エレナ",
      "「そんなのいや、恥ずかしい」"
    ]
  },
  {
    "op": "42",
    "offset": 2050,
    "index": 66,
    "value": [
      "u16:28",
      "u8:0",
      "u8:0",
      "花丸",
      "「言わないとやめるよ」"
    ]
  },
  {
    "op": "41",
    "offset": 2083,
    "index": 67,
    "value": [
      "u16:29",
      "u8:0",
      "　少し腰を止めてみる。"
    ]
  },
  {
    "op": "23",
