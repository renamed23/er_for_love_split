    "value": [
      "u16:5",
      "u8:0",
      "u8:0",
      "エレナ",
      "「くす。御飯、何食べたい？」"
    ]
  },
  {
    "op": "41",
    "offset": 433,
    "index": 29,
    "value": [
      "u16:6",
      "u8:0",
      "　エレナさんがエプロンでいた。"
    ]
  },
  {
    "op": "41",
    "offset": 468,
    "index": 30,
    "value": [
      "u16:7",
      "u8:0",
      "　それも──下は何も着けていなかった。"
    ]
  },
  {
    "op": "42",
    "offset": 511,
    "index": 31,
    "value": [
      "u16:8",
      "u8:0",
      "u8:0",
      "花丸",
      "「エレナさん……」"
    ]
  },
  {
    "op": "23",
