    "index": 69,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "エレナ",
      "「馬鹿、ちゃんとして」"
    ]
  },
  {
    "op": "42",
    "offset": 2164,
    "index": 70,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "花丸",
      "「じゃあ、言ってごらん」"
    ]
  },
  {
    "op": "23",
