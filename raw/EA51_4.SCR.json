    ]
  },
  {
    "op": "42",
    "offset": 954,
    "index": 46,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "エレナ",
      "「そんないきなり、いやっ、あっ、や、やあん、や、やぁぁ\\n　んっ」"
    ]
  },
  {
    "op": "42",
    "offset": 1031,
    "index": 47,
    "value": [
      "u16:15",
      "u8:0",
      "u8:0",
      "花丸",
      "「エレナさん、もう濡れてる」"
    ]
  },
  {
    "op": "23",
    "offset": 1070,
    "index": 48,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
