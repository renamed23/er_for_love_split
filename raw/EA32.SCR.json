  {
    "op": "41",
    "offset": 76,
    "index": 10,
    "value": [
      "u16:0",
      "u8:0",
      "　海は楽しかった。"
    ]
  },
  {
    "op": "41",
    "offset": 99,
    "index": 11,
    "value": [
      "u16:1",
      "u8:0",
      "　いっぱいエッチなこともしちゃったし……花丸くん、凄く\\n気持ちよさそうだったけど。"
    ]
  },
  {
    "op": "41",
    "offset": 186,
    "index": 12,
    "value": [
      "u16:2",
      "u8:0",
      "　くす。"
    ]
  },
  {
    "op": "41",
    "offset": 199,
    "index": 13,
    "value": [
      "u16:3",
      "u8:0",
      "　ついさっきまで、また花丸くんと電話してた。"
    ]
  },
  {
    "op": "41",
    "offset": 248,
    "index": 14,
    "value": [
      "u16:4",
      "u8:0",
      "　また三時間。"
    ]
  },
  {
    "op": "41",
    "offset": 267,
    "index": 15,
    "value": [
      "u16:5",
      "u8:0",
      "　最近、ずっと花丸くん、花丸くん、花丸くん。"
    ]
  },
  {
    "op": "41",
    "offset": 316,
    "index": 16,
    "value": [
      "u16:6",
      "u8:0",
      "　エッチしている時も、好き。"
    ]
  },
  {
    "op": "41",
    "offset": 349,
    "index": 17,
    "value": [
      "u16:7",
      "u8:0",
      "　普通に話している時も、好き。"
    ]
  },
  {
    "op": "41",
    "offset": 384,
    "index": 18,
    "value": [
      "u16:8",
      "u8:0",
      "　並んでボウリングしている時も、好き。"
    ]
  },
  {
    "op": "41",
    "offset": 427,
    "index": 19,
    "value": [
      "u16:9",
      "u8:0",
      "　時々、二人で暮らせたらな、なんて思ったりしてる。花丸\\nくんがどう思っているのかはわからないけれど。"
    ]
  },
  {
    "op": "41",
    "offset": 532,
    "index": 20,
    "value": [
      "u16:10",
      "u8:0",
      "　来年になったら、わたしは社会人。花丸くんは大学生のま\\nま。"
    ]
  },
  {
    "op": "41",
    "offset": 597,
    "index": 21,
    "value": [
      "u16:11",
      "u8:0",
      "　そんな形で終わりたくない。"
    ]
  },
  {
    "op": "41",
    "offset": 630,
    "index": 22,
    "value": [
      "u16:12",
      "u8:0",
      "　境遇が変わっても、二人いっしょ。"
    ]
  },
  {
    "op": "41",
    "offset": 669,
    "index": 23,
    "value": [
      "u16:13",
      "u8:0",
      "　花丸くんと、二人いっしょ。"
    ]
  },
  {
    "op": "41",
    "offset": 702,
    "index": 24,
    "value": [
      "u16:14",
      "u8:0",
      "　ずっと……ずっと……"
    ]
  },
