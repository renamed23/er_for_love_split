    ]
  },
  {
    "op": "42",
    "offset": 2335,
    "index": 54,
    "value": [
      "u16:24",
      "u8:0",
      "u8:0",
      "ルナ",
      "「はあ……はあ……はあ……」"
    ]
  },
  {
    "op": "41",
    "offset": 2374,
    "index": 55,
    "value": [
      "u16:25",
      "u8:0",
      "　ルナがようやく息をついた。"
    ]
  },
  {
    "op": "23",
    "offset": 2407,
    "index": 56,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1275.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2426,
    "index": 57,
    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "ルナ",
      "「気持ちよかった？」"
    ]
  },
  {
    "op": "41",
    "offset": 2457,
    "index": 58,
    "value": [
      "u16:27",
      "u8:0",
      "　目を輝かせて尋ねる。"
    ]
  },
  {
    "op": "42",
    "offset": 2484,
    "index": 59,
    "value": [
      "u16:28",
      "u8:0",
      "u8:0",
      "花丸",
      "「ルナのエッチ」"
    ]
  },
  {
    "op": "23",
    "offset": 2511,
    "index": 60,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1276.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2530,
    "index": 61,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "ルナ",
      "「くすっ。お兄ちゃんには負けるもん」"
    ]
  },
  {
    "op": "41",
    "offset": 2577,
    "index": 62,
    "value": [
      "u16:30",
      "u8:0",
      "　小憎らしいことを言う。"
    ]
  },
  {
    "op": "23",
    "offset": 2606,
    "index": 63,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1277.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2625,
    "index": 64,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "ルナ",
      "「今度はお兄ちゃんが気持ちよくして」"
    ]
  },
  {
    "op": "42",
    "offset": 2672,
    "index": 65,
    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "花丸",
      "「何してほしいんだよ」"
    ]
  },
  {
    "op": "23",
    "offset": 2705,
    "index": 66,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1278.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2724,
    "index": 67,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "ルナ",
      "「……お兄ちゃんの、入れて」"
    ]
  },
  {
    "op": "41",
    "offset": 2763,
    "index": 68,
    "value": [
      "u16:34",
      "u8:0",
      "　その一言に、またクラッときて後ろからつかみかかった。"
    ]
  },
