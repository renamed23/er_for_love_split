    "value": [
      "u16:4",
      "u8:0",
      "u8:0",
      "親父",
      "「もう大学生になったんだから、いいんだぞ」"
    ]
  },
  {
    "op": "42",
    "offset": 422,
    "index": 18,
    "value": [
      "u16:5",
      "u8:0",
      "u8:0",
      "花丸",
      "「けど、おれがやらなきゃ誰が作るんだ？　朝飯」"
    ]
  },
  {
    "op": "41",
