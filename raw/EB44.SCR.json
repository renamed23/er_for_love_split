    ]
  },
  {
    "op": "41",
    "offset": 151,
    "index": 11,
    "value": [
      "u16:3",
      "u8:0",
      "　あんたのせいよ、と樹里には言われた。"
    ]
  },
  {
    "op": "41",
    "offset": 194,
    "index": 12,
    "value": [
      "u16:4",
      "u8:0",
