    "value": [
      "u16:0",
      "u8:0",
      "　なんだか、帰って来たら力が抜けちゃった。"
    ]
  },
  {
    "op": "41",
    "offset": 109,
    "index": 9,
    "value": [
      "u16:1",
      "u8:0",
      "　花丸が……やめちゃった。"
    ]
  },
  {
    "op": "41",
