    ]
  },
  {
    "op": "42",
    "offset": 205,
    "index": 13,
    "value": [
      "u16:2",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あなたが風丸くんと結婚したら、わたしが義理のお姉様に\\n　なるわけよ」"
    ]
  },
  {
