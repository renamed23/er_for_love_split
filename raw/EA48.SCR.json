  {
    "op": "41",
    "offset": 448,
    "index": 26,
    "value": [
      "u16:4",
      "u8:0",
      "　言った直後に樹里が笑う。"
    ]
  },
  {
    "op": "23",
    "offset": 479,
    "index": 27,
    "value": [
      "u8:0",
      "u16:65535",
