      "u8:0",
      "樹里",
      "「そっか。じゃ、同じ家族になるのか」"
    ]
  },
  {
    "op": "41",
    "offset": 147,
    "index": 11,
    "value": [
      "u16:1",
      "u8:0",
      "　なぜだか樹里はうれしそうだった。"
    ]
  },
  {
    "op": "23",
    "offset": 186,
    "index": 12,
    "value": [
      "u8:0",
      "u16:65535",
