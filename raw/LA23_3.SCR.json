      "u8:3",
      "u16:27",
      "u16:0",
      "u32:35",
      "u8:0"
    ]
  },
  {
    "op": "41",
    "offset": 3832,
    "index": 175,
    "value": [
      "u16:51",
      "u8:0",
      "　来年、絶対行こうな！"
    ]
  },
