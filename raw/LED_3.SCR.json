    "value": [
      "u16:0",
      "u8:0",
      "　──青い。"
    ]
  },
  {
    "op": "41",
    "offset": 71,
    "index": 9,
    "value": [
      "u16:1",
      "u8:0",
      "　空が──青い。"
    ]
  },
  {
    "op": "41",
    "offset": 92,
    "index": 10,
    "value": [
      "u16:2",
      "u8:0",
      "　まるで数年前のあの日のように──"
    ]
  },
  {
