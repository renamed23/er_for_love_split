      "u16:6",
      "u8:0",
      "u8:0",
      "親父",
      "「風丸は」"
    ]
  },
  {
    "op": "42",
    "offset": 523,
    "index": 36,
    "value": [
      "u16:7",
      "u8:0",
      "u8:0",
      "花丸",
      "「今日は樹里さんとこに泊まり」"
    ]
  },
  {
    "op": "42",
    "offset": 564,
    "index": 37,
    "value": [
      "u16:8",
      "u8:0",
      "u8:0",
      "親父",
      "「外泊か。おまえはいいのか」"
    ]
  },
  {
    "op": "42",
    "offset": 603,
    "index": 38,
    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "花丸",
      "「今週行くから」"
    ]
  },
  {
    "op": "42",
    "offset": 630,
    "index": 39,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "親父",
      "「そうか。──今度な」"
    ]
  },
  {
    "op": "42",
    "offset": 663,
    "index": 40,
    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "花丸",
      "「何」"
    ]
  },
  {
    "op": "42",
    "offset": 680,
    "index": 41,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "親父",
      "「うん。風丸にはまだ話をするなよ。父さん、再婚しようと\\n　思ってるんだ」"
    ]
  },
  {
    "op": "42",
    "offset": 763,
    "index": 42,
    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "花丸",
      "「へ？　再婚？　そんな雲から湧いたような話──」"
    ]
  },
  {
    "op": "41",
    "offset": 822,
    "index": 43,
    "value": [
      "u16:14",
      "u8:0",
      "　言いかけて、親父が春ごろに口にしていたことを思い出し\\nた。母さんはいらないか？　とか言ってなかったか？"
    ]
  },
  {
    "op": "42",
    "offset": 931,
    "index": 44,
    "value": [
      "u16:15",
      "u8:0",
      "u8:0",
      "花丸",
      "「相手、誰なんだよ」"
    ]
  },
  {
    "op": "42",
    "offset": 962,
    "index": 45,
    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "親父",
      "「うん、まあな」"
    ]
  },
  {
    "op": "41",
    "offset": 989,
    "index": 46,
    "value": [
      "u16:17",
      "u8:0",
      "　いきなり親父が黙る。"
    ]
  },
  {
    "op": "42",
    "offset": 1016,
    "index": 47,
    "value": [
      "u16:18",
      "u8:0",
      "u8:0",
      "親父",
      "「風丸、賛成するかな」"
    ]
  },
  {
    "op": "42",
    "offset": 1049,
    "index": 48,
    "value": [
      "u16:19",
      "u8:0",
      "u8:0",
      "花丸",
      "「あいつだっていつまでも子供じゃないんだし」"
    ]
  },
  {
    "op": "42",
    "offset": 1104,
    "index": 49,
    "value": [
      "u16:20",
      "u8:0",
      "u8:0",
      "親父",
      "「そうだな。いつまでも、おまえに家のことをさせるわけに\\n　もいかないしな」"
    ]
  },
  {
    "op": "42",
    "offset": 1189,
    "index": 50,
    "value": [
      "u16:21",
      "u8:0",
      "u8:0",
      "花丸",
      "「大学の間ぐらいは平気だぞ」"
    ]
  },
  {
    "op": "42",
    "offset": 1228,
    "index": 51,
    "value": [
      "u16:22",
      "u8:0",
      "u8:0",
      "親父",
      "「そうはいかんだろう。もうずっと……」"
    ]
  },
  {
    "op": "41",
    "offset": 1277,
    "index": 52,
    "value": [
      "u16:23",
      "u8:0",
      "　親父は黙った。"
    ]
  },
  {
    "op": "41",
    "offset": 1298,
    "index": 53,
    "value": [
      "u16:24",
      "u8:0",
      "　小学校６年の時に母さんが亡くなってから、もう８年以上。\\n家事はおれの仕事だった。"
    ]
  },
  {
    "op": "42",
    "offset": 1385,
    "index": 54,
    "value": [
      "u16:25",
      "u8:0",
      "u8:0",
      "親父",
      "「いい人だから。おまえも会えば気に入るよ」"
    ]
  },
  {
    "op": "42",
    "offset": 1438,
    "index": 55,
    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん」"
    ]
  },
  {
    "op": "42",
    "offset": 1457,
    "index": 56,
    "value": [
      "u16:27",
      "u8:0",
      "u8:0",
      "親父",
      "「風呂は沸いてるのか」"
    ]
  },
  {
    "op": "41",
    "offset": 1490,
    "index": 57,
    "value": [
      "u16:28",
      "u8:0",
      "　親父は話題を変えた。"
    ]
  },
  {
    "op": "42",
    "offset": 1517,
    "index": 58,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "花丸",
      "「温泉の素は入ってないぞ」"
    ]
  },
  {
    "op": "42",
    "offset": 1554,
    "index": 59,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "親父",
      "「じゃあ、入ってくるかな」"
    ]
  },
  {
