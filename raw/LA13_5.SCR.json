    ]
  },
  {
    "op": "42",
    "offset": 348,
    "index": 16,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "ルナ",
      "「出して……お兄ちゃんのいっぱい出して……ルナが飲んで\\n　あげる……ちゅうううっ、ちゅぼぉぉぉぉぉっ、ちゅうう\\n　うううううっ！」"
    ]
  },
  {
    "op": "42",
    "offset": 489,
    "index": 17,
    "value": [
      "u16:4",
      "u8:0",
      "u8:0",
      "花丸",
      "「あ、ああぁ、ルナっ、あぁぁっ……」"
    ]
  },
  {
    "op": "23",
    "offset": 536,
    "index": 18,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
