    "op": "41",
    "offset": 1542,
    "index": 35,
    "value": [
      "u16:23",
      "u8:0",
      "　月曜日。"
    ]
  },
  {
    "op": "49",
    "offset": 1557,
    "index": 36,
    "value": [
      "u8:0",
      "u8:0",
