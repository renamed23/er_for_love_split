    ]
  },
  {
    "op": "41",
    "offset": 1867,
    "index": 47,
    "value": [
      "u16:27",
      "u8:0",
      "　昨日までお兄ちゃんといっしょだったのにな……。"
    ]
  },
  {
    "op": "49",
    "offset": 1920,
    "index": 48,
    "value": [
      "u8:0",
      "u8:0",
