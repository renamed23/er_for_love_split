    ]
  },
  {
    "op": "41",
    "offset": 2569,
    "index": 85,
    "value": [
      "u16:41",
      "u8:0",
      "　また寂しくなってしまった。"
    ]
  },
  {
    "op": "41",
    "offset": 2602,
    "index": 86,
    "value": [
      "u16:42",
      "u8:0",
      "　雨が降ったからかもしれない。"
    ]
  },
  {
    "op": "41",
    "offset": 2637,
    "index": 87,
    "value": [
      "u16:43",
      "u8:0",
      "　なんだか、子供の時を思い出す。"
    ]
  },
  {
    "op": "41",
    "offset": 2674,
    "index": 88,
    "value": [
      "u16:44",
      "u8:0",
      "　まだ、お兄ちゃんのお母さん──つまり伯母さんが生きて\\nいた時。"
    ]
  },
  {
    "op": "41",
    "offset": 2743,
    "index": 89,
    "value": [
      "u16:45",
      "u8:0",
      "　母方のおばあちゃんの家に遊びに行った。わたしが着くと、\\nお兄ちゃんと風丸お兄ちゃんは、近所の川へ出かけてしまっ\\nていた。"
    ]
  },
  {
    "op": "41",
    "offset": 2870,
    "index": 90,
    "value": [
      "u16:46",
      "u8:0",
      "　空は黒くなり始めていた。"
    ]
  },
  {
    "op": "41",
    "offset": 2901,
    "index": 91,
    "value": [
      "u16:47",
      "u8:0",
      "　雨が降るがねえ、とおばあちゃんが言った。"
    ]
  },
  {
    "op": "41",
    "offset": 2948,
    "index": 92,
    "value": [
      "u16:48",
      "u8:0",
      "　濡れてこなけりゃええがぁ。"
    ]
  },
  {
    "op": "41",
    "offset": 2981,
    "index": 93,
    "value": [
      "u16:49",
      "u8:0",
      "　傘を２つ持ってわたしは飛び出した。"
    ]
  },
  {
    "op": "41",
    "offset": 3022,
    "index": 94,
    "value": [
      "u16:50",
      "u8:0",
      "　途中、雨が降り出した。"
    ]
  },
  {
    "op": "41",
    "offset": 3051,
    "index": 95,
    "value": [
      "u16:51",
      "u8:0",
      "　舗装されていない田舎の道に、ザアザア雨が降り注ぐ。"
    ]
  },
  {
    "op": "41",
    "offset": 3108,
    "index": 96,
    "value": [
      "u16:52",
      "u8:0",
      "　川に出てみた。"
    ]
  },
  {
    "op": "41",
    "offset": 3129,
    "index": 97,
    "value": [
      "u16:53",
      "u8:0",
      "　もう土色になっていた。"
    ]
  },
  {
    "op": "41",
    "offset": 3158,
    "index": 98,
    "value": [
