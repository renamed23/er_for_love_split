    "index": 4,
    "value": [
      "u16:2",
      "u8:0",
      "u8:0",
      "青山",
      "「そううまく行くと思ってなかったけどさ……」"
    ]
  },
  {
    "op": "42",
    "offset": 137,
    "index": 5,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん……。けど、まだ会ったばっかりだろ？　いきなりデー\\n　トってのは、さすがに難しいんじゃないかな」"
    ]
  },
  {
    "op": "42",
    "offset": 250,
    "index": 6,
    "value": [
      "u16:4",
      "u8:0",
      "u8:0",
      "青山",
      "「けど、おまえ、お局様とうまくやったじゃないか」"
    ]
  },
  {
    "op": "42",
    "offset": 309,
    "index": 7,
    "value": [
      "u16:5",
      "u8:0",
      "u8:0",
      "花丸",
