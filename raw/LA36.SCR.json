    "value": [
      "u16:0",
      "u8:0",
      "　１０月２８日、月曜日。"
    ]
  },
  {
    "op": "49",
    "offset": 90,
    "index": 9,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
