    ]
  },
  {
    "op": "41",
    "offset": 1906,
    "index": 64,
    "value": [
      "u16:32",
      "u8:0",
      "　お兄ちゃんが帰ってからも勉強した。気がついたら夜中の\\n１時になってた。もう１時間したら、寝よう……。"
    ]
  },
  {
