    ]
  },
  {
    "op": "42",
    "offset": 804,
    "index": 33,
    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "親父",
      "「正直なところ、どう思う。ありさとうまくやっていけそう\\n　か」"
    ]
  },
  {
    "op": "42",
    "offset": 877,
    "index": 34,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "花丸",
      "「大丈夫じゃないの？」"
    ]
  },
  {
    "op": "42",
    "offset": 910,
    "index": 35,
    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "親父",
      "「エレナちゃんは」"
    ]
  },
  {
    "op": "42",
    "offset": 939,
    "index": 36,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれは平気だけど。この間町で会ったし。ちょっと毒舌だ\\n　けどね」"
    ]
  },
  {
    "op": "42",
    "offset": 1016,
    "index": 37,
    "value": [
      "u16:15",
      "u8:0",
      "u8:0",
      "親父",
      "「美人には刺があるもんだ」"
    ]
  },
  {
    "op": "42",
    "offset": 1053,
    "index": 38,
    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "花丸",
      "「ありささんにはないのか」"
    ]
  },
  {
    "op": "41",
    "offset": 1090,
    "index": 39,
    "value": [
      "u16:17",
      "u8:0",
      "　親父は笑っただけだった。"
    ]
  },
  {
    "op": "42",
    "offset": 1121,
    "index": 40,
    "value": [
      "u16:18",
      "u8:0",
      "u8:0",
      "親父",
      "「あの人も、夫をなくしていてな」"
    ]
  },
  {
    "op": "42",
    "offset": 1164,
    "index": 41,
    "value": [
      "u16:19",
      "u8:0",
      "u8:0",
      "花丸",
      "「ふ～ん」"
    ]
  },
  {
    "op": "42",
    "offset": 1185,
    "index": 42,
    "value": [
      "u16:20",
      "u8:0",
      "u8:0",
      "親父",
      "「まあ、同じ独り身ってわけだ」"
    ]
  },
  {
    "op": "41",
    "offset": 1226,
    "index": 43,
    "value": [
      "u16:21",
      "u8:0",
      "　おれは黙って親父の酒を注いだ。"
    ]
  },
  {
    "op": "42",
    "offset": 1263,
    "index": 44,
    "value": [
      "u16:22",
      "u8:0",
      "u8:0",
      "親父",
      "「結婚が決まったら、来月からもう住むことになると思う」"
    ]
  },
  {
    "op": "42",
    "offset": 1328,
    "index": 45,
    "value": [
      "u16:23",
      "u8:0",
      "u8:0",
      "花丸",
      "「そんなに早いの？」"
    ]
  },
  {
    "op": "42",
    "offset": 1359,
    "index": 46,
    "value": [
      "u16:24",
      "u8:0",
      "u8:0",
      "親父",
      "「うん……どうせなら早いほうがいいだろうってな。おまえ\\n　を早く楽にしてやりたいし」"
    ]
  },
  {
    "op": "42",
    "offset": 1454,
    "index": 47,
    "value": [
      "u16:25",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれは平気だけどさ。最近はよくさぼってるし」"
    ]
  },
  {
    "op": "42",
    "offset": 1511,
    "index": 48,
    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "親父",
      "「うん……」"
    ]
  },
  {
    "op": "41",
    "offset": 1534,
    "index": 49,
    "value": [
      "u16:27",
      "u8:0",
      "　親父は酒を呷った。"
    ]
  },
  {
    "op": "42",
    "offset": 1559,
    "index": 50,
    "value": [
      "u16:28",
      "u8:0",
      "u8:0",
      "親父",
      "「今度の墓参りで、うまい具合に仲良くなってくれるといい\\n　んだけどな」"
    ]
  },
  {
    "op": "42",
    "offset": 1640,
    "index": 51,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "花丸",
      "「母さんに神頼みする？」"
    ]
  },
  {
    "op": "42",
    "offset": 1675,
    "index": 52,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "親父",
      "「今回のことも、ちゃんと報告せにゃいかんしな」"
    ]
  },
  {
    "op": "22",
    "offset": 1732,
    "index": 53,
    "value": [
      "u8:1",
