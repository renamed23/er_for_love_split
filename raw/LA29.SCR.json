    ]
  },
  {
    "op": "41",
    "offset": 693,
    "index": 27,
    "value": [
      "u16:10",
      "u8:0",
      "　親父はダイニングテーブルについた。おれも腰を下ろした。"
    ]
  },
  {
    "op": "49",
    "offset": 754,
    "index": 28,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 758,
    "index": 29,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 762,
    "index": 30,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "W_B000B"
    ]
  },
  {
    "op": "48",
    "offset": 780,
    "index": 31,
    "value": [
      "u8:1",
      "u16:112",
      "u16:0",
      "u32:0",
      "u8:0",
      "W804_00"
    ]
  },
  {
    "op": "4A",
    "offset": 799,
    "index": 32,
    "value": [
