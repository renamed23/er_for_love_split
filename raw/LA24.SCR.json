    "index": 41,
    "value": [
      "u16:22",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 1205,
    "index": 42,
    "value": [
      "u16:23",
      "u8:0",
      "　海……行きたかったな……"
    ]
  },
  {
    "op": "41",
    "offset": 1236,
    "index": 43,
    "value": [
      "u16:24",
      "u8:0",
      "　ふと、思う。"
    ]
  },
  {
    "op": "41",
    "offset": 1255,
    "index": 44,
    "value": [
      "u16:25",
      "u8:0",
      "　あとで、樹里さんと風丸お兄ちゃんが海に行ったことを聞\\nかされた。"
    ]
  },
  {
    "op": "41",
    "offset": 1326,
    "index": 45,
    "value": [
      "u16:26",
      "u8:0",
      "　……わたしも……行きたかったな……。"
    ]
  },
