    ]
  },
  {
    "op": "42",
    "offset": 5433,
    "index": 168,
    "value": [
      "u16:88",
      "u8:0",
      "u8:0",
      "女性",
      "「え……嘘」"
    ]
  },
  {
    "op": "41",
    "offset": 5456,
    "index": 169,
    "value": [
      "u16:89",
      "u8:0",
      "　彼女が驚く。"
    ]
  },
  {
    "op": "42",
    "offset": 5475,
    "index": 170,
    "value": [
      "u16:90",
      "u8:0",
      "u8:0",
      "花丸",
