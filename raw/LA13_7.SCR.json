    "value": [
      "u16:91",
      "u8:0",
      "u8:0",
      "女性",
      "「ええ……」"
    ]
  },
  {
    "op": "42",
    "offset": 5550,
    "index": 173,
    "value": [
      "u16:92",
      "u8:0",
      "u8:0",
      "花丸",
      "「傘、入っていきます？」"
    ]
  },
  {
    "op": "23",
    "offset": 5585,
    "index": 174,
    "value": [
      "u8:0",
      "u16:65535",
