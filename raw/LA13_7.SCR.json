    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "青山",
      "「ルナちゃん、元気してる？」"
    ]
  },
  {
    "op": "42",
    "offset": 2118,
    "index": 71,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "花丸",
      "「ああ、してるよ」"
    ]
  },
  {
    "op": "41",
    "offset": 2147,
    "index": 72,
    "value": [
      "u16:34",
      "u8:0",
      "　まさか今日、ほっぺたにチューをもらってきましたなんて、\\n言えるわけがない。"
    ]
  },
  {
    "op": "42",
    "offset": 2228,
    "index": 73,
    "value": [
      "u16:35",
      "u8:0",
      "u8:0",
      "青山",
      "「そっか……おれのこと……何か言ってた？」"
    ]
  },
  {
    "op": "42",
    "offset": 2281,
    "index": 74,
    "value": [
      "u16:36",
      "u8:0",
      "u8:0",
      "花丸",
      "「別に」"
    ]
  },
  {
