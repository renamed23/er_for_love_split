      "u16:82",
      "u8:0",
      "u8:0",
      "女性",
      "「獅子堂くん……」"
    ]
  },
  {
    "op": "41",
    "offset": 5240,
    "index": 161,
    "value": [
      "u16:83",
      "u8:0",
      "　間違われた。"
    ]
  },
  {
    "op": "41",
    "offset": 5259,
    "index": 162,
    "value": [
      "u16:84",
      "u8:0",
      "　風丸の……知り合い？"
    ]
  },
  {
    "op": "42",
    "offset": 5286,
    "index": 163,
    "value": [
      "u16:85",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれ、風丸じゃないんです」"
    ]
  },
  {
    "op": "23",
    "offset": 5325,
    "index": 164,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_9001.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 5344,
    "index": 165,
    "value": [
      "u16:86",
      "u8:0",
      "u8:0",
      "女性",
      "「え？」"
    ]
  },
  {
    "op": "42",
    "offset": 5363,
    "index": 166,
    "value": [
      "u16:87",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれ、双子なんです。兄貴の方なんです」"
    ]
  },
  {
    "op": "23",
    "offset": 5414,
    "index": 167,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
