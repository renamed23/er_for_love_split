    "value": [
      "u16:8",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あ」"
    ]
  },
  {
    "op": "42",
    "offset": 893,
    "index": 44,
    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "花丸",
      "「あれ？　乗ってたの？」"
    ]
  },
  {
    "op": "23",
    "offset": 928,
    "index": 45,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2372.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 947,
    "index": 46,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "エレナ",
      "「え……うん……」"
    ]
  },
  {
    "op": "41",
    "offset": 978,
    "index": 47,
    "value": [
      "u16:11",
      "u8:0",
      "　久々の偶然だった。買い物袋を持っている。駅のスーパー\\nまで買い出しに来たのだろうか。"
    ]
  },
  {
    "op": "21",
    "offset": 1069,
    "index": 48,
    "value": [
      "u8:1",
      "u16:1000",
      "BGM11"
    ]
  },
  {
    "op": "49",
    "offset": 1079,
    "index": 49,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 1083,
    "index": 50,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 1087,
    "index": 51,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
