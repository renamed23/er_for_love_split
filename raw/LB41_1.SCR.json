    "offset": 3609,
    "index": 142,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 3613,
    "index": 143,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "E101"
    ]
  },
  {
    "op": "4A",
    "offset": 3628,
    "index": 144,
    "value": [
