    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 2381,
    "index": 104,
    "value": [
      "u16:33",
      "u8:0",
      "　エレナさんがおれを抱きしめた。"
    ]
  },
  {
    "op": "41",
    "offset": 2418,
    "index": 105,
    "value": [
      "u16:34",
      "u8:0",
      "　おれは──初めて泣いた。母さんが亡くなった時も泣かな\\nかったのに、初めて泣いた。"
    ]
  },
  {
    "op": "41",
    "offset": 2505,
    "index": 106,
    "value": [
      "u16:35",
      "u8:0",
      "　エレナさんの腕のなかで。"
    ]
  },
  {
    "op": "41",
    "offset": 2536,
    "index": 107,
    "value": [
      "u16:36",
      "u8:0",
      "　ひとつの恋が──終わった。"
    ]
  },
  {
    "op": "49",
    "offset": 2569,
    "index": 108,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
