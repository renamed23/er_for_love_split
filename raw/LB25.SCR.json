      "u16:1",
      "u8:0",
      "u8:0",
      "ルナ",
      "「う～ん、何にしよっかなあ」"
    ]
  },
  {
    "op": "41",
    "offset": 170,
    "index": 12,
    "value": [
      "u16:2",
      "u8:0",
