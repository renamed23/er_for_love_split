    ]
  },
  {
    "op": "42",
    "offset": 1619,
    "index": 61,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ごめんね……今週、ずっと変なの。ドアの外でね、ハアハ\\n　ア言う声が聞こえるの」"
    ]
  },
  {
    "op": "42",
    "offset": 1710,
    "index": 62,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "花丸",
      "「ドアの前？」"
    ]
  },
  {
    "op": "23",
    "offset": 1735,
    "index": 63,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0245.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1754,
    "index": 64,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "ルナ",
      "「初めはね、ランプだったの。窓を開けたら下の方でランプ\\n　か何かやってんの。何かなって思ってたら、次の日に手紙\\n　が入ってて。昨日の合図、見えた？　って、怖い～～っ！」"
    ]
  },
  {
    "op": "41",
    "offset": 1933,
    "index": 65,
    "value": [
      "u16:32",
      "u8:0",
      "　ルナのテンションがいきなり上がる。"
    ]
  },
  {
    "op": "42",
    "offset": 1974,
    "index": 66,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "花丸",
