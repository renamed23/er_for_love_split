    ]
  },
  {
    "op": "42",
    "offset": 356,
    "index": 17,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "エレナ",
      "「今ね、勉強してるところなの。花丸くん、来ない？」"
    ]
  },
  {
    "op": "41",
    "offset": 419,
    "index": 18,
    "value": [
      "u16:4",
      "u8:0",
      "　おれは時計を見た。"
    ]
  },
  {
    "op": "41",
    "offset": 444,
    "index": 19,
    "value": [
      "u16:5",
      "u8:0",
      "　夜の１０時。行けない時間ではない。"
    ]
  },
  {
    "op": "42",
    "offset": 485,
    "index": 20,
    "value": [
      "u16:6",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん、行く」"
    ]
  },
  {
    "op": "23",
    "offset": 510,
    "index": 21,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
