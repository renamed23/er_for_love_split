    "value": [
      "u16:20",
      "u8:0",
      "u8:0",
      "ルナ",
      "「怖いよぉ」"
    ]
  },
  {
    "op": "41",
    "offset": 1217,
    "index": 49,
    "value": [
      "u16:21",
      "u8:0",
      "　いきなり声が半泣きだ。おれは荷物を下ろした。"
    ]
  },
