  {
    "op": "42",
    "offset": 2730,
    "index": 74,
    "value": [
      "u16:38",
      "u8:0",
      "u8:0",
      "ルナ",
      "「またあの人？」"
    ]
  },
  {
    "op": "41",
    "offset": 2757,
    "index": 75,
    "value": [
      "u16:39",
      "u8:0",
      "　青山の話をすると、やっぱりルナはいやそうな顔をした。"
    ]
  },
  {
    "op": "42",
    "offset": 2816,
    "index": 76,
    "value": [
      "u16:40",
      "u8:0",
      "u8:0",
      "花丸",
      "「そんな顔するなよ」"
    ]
  },
  {
    "op": "23",
    "offset": 2847,
    "index": 77,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1210.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2866,
    "index": 78,
    "value": [
      "u16:41",
      "u8:0",
      "u8:0",
      "ルナ",
      "「だって、あの人約束破るんだもん」"
    ]
  },
  {
    "op": "42",
    "offset": 2911,
    "index": 79,
    "value": [
      "u16:42",
      "u8:0",
      "u8:0",
      "花丸",
      "「いいだろ、もう仲直りしたんだし」"
    ]
  },
  {
    "op": "23",
    "offset": 2956,
    "index": 80,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1211.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2975,
    "index": 81,
    "value": [
      "u16:43",
      "u8:0",
      "u8:0",
      "ルナ",
      "「だってえ」"
    ]
  },
  {
    "op": "42",
    "offset": 2998,
    "index": 82,
    "value": [
      "u16:44",
      "u8:0",
      "u8:0",
      "花丸",
      "「デート代も向こう持ちだったんだろ？」"
    ]
  },
  {
    "op": "23",
    "offset": 3047,
    "index": 83,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1212.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 3066,
    "index": 84,
    "value": [
      "u16:45",
      "u8:0",
      "u8:0",
      "ルナ",
      "「そりゃそうだけど……約束なかったらお兄ちゃんとデート\\n　できたのに」"
    ]
  },
  {
    "op": "41",
    "offset": 3147,
    "index": 85,
    "value": [
      "u16:46",
      "u8:0",
      "　思わず笑ってしまう。"
    ]
  },
  {
    "op": "42",
    "offset": 3174,
    "index": 86,
    "value": [
      "u16:47",
      "u8:0",
      "u8:0",
      "花丸",
      "「いいから勉強しろ」"
    ]
  },
  {
