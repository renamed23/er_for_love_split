    ]
  },
  {
    "op": "41",
    "offset": 1164,
    "index": 40,
    "value": [
      "u16:17",
      "u8:0",
      "　エレナさんが乳房を揺らしながら戻ってきた。"
    ]
  },
  {
    "op": "41",
    "offset": 1213,
    "index": 41,
    "value": [
      "u16:18",
      "u8:0",
      "　──少し乳首が出ている。"
    ]
  },
  {
    "op": "23",
    "offset": 1244,
    "index": 42,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0693.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1263,
    "index": 43,
    "value": [
      "u16:19",
      "u8:0",
      "u8:0",
      "エレナ",
      "「何？」"
    ]
  },
  {
    "op": "42",
    "offset": 1284,
    "index": 44,
    "value": [
      "u16:20",
      "u8:0",
      "u8:0",
      "花丸",
      "「乳首、見えてるよ」"
    ]
  },
  {
    "op": "23",
    "offset": 1315,
    "index": 45,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0694.ogg"
    ]
  },
