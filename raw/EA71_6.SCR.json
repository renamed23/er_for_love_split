    "value": [
      "u16:4",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ねえ、行こうよ～、カラオケ行きたい～～」"
    ]
  },
  {
    "op": "41",
    "offset": 297,
    "index": 14,
    "value": [
      "u16:5",
      "u8:0",
      "　ルナがおねだりする。"
    ]
  },
  {
    "op": "42",
    "offset": 324,
    "index": 15,
    "value": [
      "u16:6",
      "u8:0",
      "u8:0",
