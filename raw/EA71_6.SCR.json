    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "ルナ",
      "「『別れても憎い人』」"
    ]
  },
  {
    "op": "42",
    "offset": 701,
    "index": 33,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "花丸",
      "「辛気臭くないか？」"
    ]
  },
  {
    "op": "23",
    "offset": 732,
    "index": 34,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
