    "index": 29,
    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "ルナ",
      "「お兄ちゃん、デュエットしよ、デュエット」"
    ]
  },
  {
    "op": "42",
    "offset": 622,
    "index": 30,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "花丸",
      "「何歌うんだよ」"
    ]
  },
  {
