    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "ルナ",
      "「今日、また実力テストあったんだ」"
    ]
  },
  {
    "op": "41",
    "offset": 1314,
    "index": 68,
    "value": [
      "u16:17",
      "u8:0",
      "　まな板の上でブロッコリーを小さく分けながらルナが言う。"
    ]
  },
  {
    "op": "42",
    "offset": 1375,
    "index": 69,
