    "value": [
      "u16:0",
      "u8:0",
      "　降り出した雨に、思わず傘を持って迎えに行ってしまった。"
    ]
  },
  {
    "op": "41",
    "offset": 123,
    "index": 9,
    "value": [
      "u16:1",
      "u8:0",
      "　初めての相合い傘。"
    ]
  },
  {
    "op": "41",
    "offset": 148,
    "index": 10,
    "value": [
      "u16:2",
      "u8:0",
      "　狭い一本の傘のなかに、花丸と二人きり。"
    ]
  },
  {
    "op": "41",
    "offset": 193,
    "index": 11,
    "value": [
      "u16:3",
      "u8:0",
      "　なんだか、ドキドキした。"
    ]
  },
  {
    "op": "41",
    "offset": 224,
    "index": 12,
    "value": [
      "u16:4",
      "u8:0",
      "　うれしかった。"
    ]
  },
  {
    "op": "41",
    "offset": 245,
    "index": 13,
    "value": [
      "u16:5",
      "u8:0",
      "　思わず花丸の横顔を見て、ちょっと見とれてしまった。花\\n丸もわたしの方を見ていたみたいだけど。"
    ]
  },
  {
    "op": "49",
    "offset": 344,
    "index": 14,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
