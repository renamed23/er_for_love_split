    "index": 8,
    "value": [
      "u16:1",
      "u8:0",
      "　まるで夫婦のような──"
    ]
  },
  {
    "op": "41",
    "offset": 118,
    "index": 9,
    "value": [
      "u16:2",
      "u8:0",
