    "offset": 2477,
    "index": 103,
    "value": [
      "u16:39",
      "u8:0",
      "u8:0",
      "ルナ",
      "「へ～え。じゃ、お兄ちゃんと対戦することあるのかな」"
    ]
  },
  {
    "op": "42",
    "offset": 2540,
    "index": 104,
    "value": [
      "u16:40",
      "u8:0",
      "u8:0",
