      "u8:0",
      "u8:0",
      "ルナ",
      "「へへへ～」"
    ]
  },
  {
    "op": "41",
    "offset": 2623,
    "index": 107,
    "value": [
      "u16:42",
      "u8:0",
      "　ルナが笑う。"
    ]
  },
