    "index": 84,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2185.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2809,
    "index": 85,
    "value": [
      "u16:41",
      "u8:0",
      "u8:0",
      "エレナ",
      "「難しい。昔の英語でしょ？　だから」"
    ]
  },
  {
