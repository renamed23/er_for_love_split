    "index": 53,
    "value": [
      "u16:17",
      "u8:0",
      "u8:0",
      "花丸",
      "「あれ、今日大学？　何しに来たの？」"
    ]
  },
  {
    "op": "23",
    "offset": 1490,
    "index": 54,
    "value": [
      "u8:0",
      "u16:65535",
