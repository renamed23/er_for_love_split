    "op": "42",
    "offset": 1509,
    "index": 55,
    "value": [
      "u16:18",
      "u8:0",
      "u8:0",
      "エレナ",
      "「卒論」"
    ]
  },
  {
    "op": "42",
    "offset": 1530,
    "index": 56,
    "value": [
      "u16:19",
      "u8:0",
      "u8:0",
      "花丸",
      "「もう終わったの？」"
    ]
  },
  {
    "op": "23",
    "offset": 1561,
    "index": 57,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2179.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1580,
    "index": 58,
    "value": [
      "u16:20",
      "u8:0",
      "u8:0",
      "エレナ",
      "「助手の人に見てもらいに行ったの」"
    ]
  },
  {
    "op": "42",
    "offset": 1627,
    "index": 59,
    "value": [
      "u16:21",
      "u8:0",
      "u8:0",
      "花丸",
      "「ふ～ん。卒論って、何書いてるの。\\n　風とともにサリンジャー？」"
    ]
  },
  {
    "op": "23",
    "offset": 1702,
    "index": 60,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2180.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1721,
    "index": 61,
    "value": [
      "u16:22",
      "u8:0",
      "u8:0",
      "エレナ",
      "「いるけどね、サリンジャーやってる子」"
    ]
  },
  {
    "op": "42",
    "offset": 1772,
    "index": 62,
    "value": [
      "u16:23",
      "u8:0",
      "u8:0",
      "花丸",
      "「じゃ、トールキン？」"
    ]
  },
  {
    "op": "23",
    "offset": 1805,
    "index": 63,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2181.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1824,
    "index": 64,
    "value": [
      "u16:24",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ああ、そういう子もいたかな」"
    ]
  },
  {
    "op": "42",
    "offset": 1867,
    "index": 65,
    "value": [
      "u16:25",
      "u8:0",
      "u8:0",
      "花丸",
      "「違うの？　じゃ、何？」"
    ]
  },
  {
    "op": "23",
    "offset": 1902,
    "index": 66,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2182.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1921,
    "index": 67,
    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ミルトン」"
    ]
  },
  {
    "op": "41",
    "offset": 1946,
    "index": 68,
    "value": [
      "u16:27",
      "u8:0",
      "　へえ、と唸ってしまった。"
    ]
  },
  {
    "op": "41",
    "offset": 1977,
    "index": 69,
    "value": [
      "u16:28",
      "u8:0",
      "　ヨーロッパ各国には、たいてい文豪や大詩人というべき存\\n在がいる。"
    ]
  },
  {
    "op": "41",
    "offset": 2048,
    "index": 70,
    "value": [
      "u16:29",
      "u8:0",
      "　スペインなら、『ドン・キホーテ』のセルバンテス。"
    ]
  },
  {
    "op": "41",
    "offset": 2103,
    "index": 71,
    "value": [
      "u16:30",
      "u8:0",
      "　イタリアなら、『神曲』のダンテ。"
    ]
  },
  {
    "op": "41",
    "offset": 2142,
    "index": 72,
    "value": [
      "u16:31",
      "u8:0",
      "　ドイツなら『ファウスト』のゲーテ。"
    ]
  },
  {
    "op": "41",
    "offset": 2183,
    "index": 73,
    "value": [
      "u16:32",
      "u8:0",
      "　フランスなら、\\n　『レ・ミゼラブル』のヴィクトル・ユーゴー。"
    ]
  },
  {
    "op": "41",
    "offset": 2250,
    "index": 74,
    "value": [
      "u16:33",
      "u8:0",
      "　そしてイギリスは、『マクベス』『オセロー』のシェイク\\nスピアと、『失楽園』のミルトン。"
    ]
  },
  {
    "op": "41",
    "offset": 2343,
    "index": 75,
    "value": [
      "u16:34",
      "u8:0",
      "　『失楽園』は、地獄に叩き落とされたサタンが復讐を目論\\nむところから人間が楽園を追い出されるまでを描いた大叙事\\n詩だ。イギリスが生んだキリスト教文学の傑作である。"
    ]
  },
  {
    "op": "42",
    "offset": 2510,
    "index": 76,
    "value": [
      "u16:35",
      "u8:0",
      "u8:0",
      "花丸",
      "「じゃ、Lost Paradiseやるんだ」"
    ]
  },
  {
    "op": "23",
    "offset": 2552,
    "index": 77,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2183.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2571,
    "index": 78,
    "value": [
      "u16:36",
      "u8:0",
      "u8:0",
      "エレナ",
      "「Paradise Lost。逆さまよ。ローストビーフじゃないんだ\\n　から」"
    ]
  },
  {
    "op": "42",
    "offset": 2647,
    "index": 79,
    "value": [
      "u16:37",
      "u8:0",
      "u8:0",
      "花丸",
      "「へえ、フランス語みたい」"
    ]
  },
  {
    "op": "23",
    "offset": 2684,
    "index": 80,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_2184.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2703,
    "index": 81,
    "value": [
      "u16:38",
      "u8:0",
      "u8:0",
      "エレナ",
      "「昔の詩だからね」"
    ]
  },
  {
    "op": "41",
    "offset": 2734,
    "index": 82,
    "value": [
      "u16:39",
      "u8:0",
      "　とエレナさんが答える。"
    ]
  },
  {
    "op": "42",
    "offset": 2763,
    "index": 83,
    "value": [
      "u16:40",
      "u8:0",
      "u8:0",
      "花丸",
      "「おもしろい？」"
    ]
  },
  {
    "op": "23",
