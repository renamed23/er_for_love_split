    "index": 322,
    "value": [
      "u16:124",
      "u8:0",
      "　ちょっとかわいそうだったけど、ほっとした。"
    ]
  },
  {
    "op": "41",
    "offset": 7561,
    "index": 323,
    "value": [
      "u16:125",
      "u8:0",
