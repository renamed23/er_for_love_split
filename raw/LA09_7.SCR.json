    "index": 39,
    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "ルナ",
      "「やっ、やぁん、お兄ちゃんの馬鹿、やぁぁぁん」"
    ]
  },
  {
    "op": "42",
    "offset": 1185,
    "index": 40,
    "value": [
      "u16:17",
      "u8:0",
      "u8:0",
      "花丸",
