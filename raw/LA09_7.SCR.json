    "value": [
      "u16:58",
      "u8:0",
      "u8:0",
      "ルナ",
      "「やぁぁん、やっ、やぁぁぁん、やっ、やぁぁぁん、あん、\\n　あああああん、あっ、ああああああっ」"
    ]
  },
  {
    "op": "41",
