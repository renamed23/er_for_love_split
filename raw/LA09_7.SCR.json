    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あん、やっ……そこ、やっ……あ……あぁぁぁんっ」"
    ]
  },
  {
    "op": "42",
    "offset": 1991,
    "index": 58,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "花丸",
      "「ルナ、入れちゃうよ」"
    ]
  },
  {
    "op": "41",
    "offset": 2024,
    "index": 59,
    "value": [
      "u16:32",
      "u8:0",
