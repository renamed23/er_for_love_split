    "value": [
      "u16:2",
      "u8:0",
      "u8:0",
      "ルナ",
      "「やん、お兄ちゃんのエッチ～～」"
    ]
  },
  {
    "op": "42",
    "offset": 239,
    "index": 15,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "花丸",
      "「ちゃんと解かないともっともみもみしちゃうぞ～～」"
