    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "花丸",
      "「出しすぎだよ、おまえ」"
    ]
  },
  {
    "op": "41",
    "offset": 819,
    "index": 45,
    "value": [
      "u16:10",
      "u8:0",
      "　おれは指を突っ込んで舐めてみた。"
    ]
  },
