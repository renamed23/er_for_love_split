      "SE_DCHIM.ogg"
    ]
  },
  {
    "op": "41",
    "offset": 9098,
    "index": 226,
    "value": [
      "u16:143",
      "u8:0",
      "　あれ？　誰だろ。"
    ]
  },
  {
    "op": "26",
    "offset": 9121,
    "index": 227,
    "value": [
      "u16:0"
    ]
  },
  {
    "op": "25",
    "offset": 9124,
    "index": 228,
    "value": [
      "u8:0",
      "u16:0",
      "SE_DCHIM.ogg"
    ]
  },
  {
    "op": "41",
    "offset": 9141,
    "index": 229,
    "value": [
      "u16:144",
      "u8:0",
      "　お兄ちゃんかな？"
    ]
  },
  {
    "op": "41",
    "offset": 9164,
    "index": 230,
    "value": [
      "u16:145",
      "u8:0",
      "　──そんなわけないか。"
    ]
  },
  {
    "op": "41",
    "offset": 9193,
    "index": 231,
    "value": [
      "u16:146",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 9204,
    "index": 232,
    "value": [
      "u16:147",
      "u8:0",
      "　もう、こんな時間か。そろそろ、バイトの準備しなきゃな。"
    ]
  },
  {
    "op": "41",
    "offset": 9265,
    "index": 233,
    "value": [
      "u16:148",
      "u8:0",
      "　……行きたくないなあ。"
    ]
  },
  {
    "op": "26",
    "offset": 9294,
    "index": 234,
    "value": [
      "u16:0"
    ]
  },
  {
    "op": "25",
    "offset": 9297,
    "index": 235,
    "value": [
      "u8:0",
      "u16:0",
      "SE_DCHIM.ogg"
    ]
  },
  {
    "op": "41",
    "offset": 9314,
    "index": 236,
    "value": [
      "u16:149",
      "u8:0",
      "　しつこいな。"
    ]
  },
  {
    "op": "41",
    "offset": 9333,
    "index": 237,
    "value": [
      "u16:150",
      "u8:0",
      "　新聞の勧誘かな。"
    ]
  },
  {
    "op": "26",
    "offset": 9356,
    "index": 238,
    "value": [
      "u16:0"
    ]
  },
  {
    "op": "25",
