    "index": 239,
    "value": [
      "u8:0",
      "u16:0",
      "SE_DCHIM.ogg"
    ]
  },
  {
    "op": "41",
    "offset": 9376,
    "index": 240,
    "value": [
      "u16:151",
      "u8:0",
      "　んもう。"
    ]
  },
