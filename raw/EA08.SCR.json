    "value": [
      "u16:0",
      "u8:0",
      "　また、ママは今日もお出かけだった。\\n　そして、わたしもちょっと遠くまでお出かけ。"
    ]
  },
  {
    "op": "41",
    "offset": 163,
    "index": 11,
    "value": [
      "u16:1",
      "u8:0",
      "　武山まで行くのは、初めてだった。"
    ]
  },
  {
    "op": "41",
    "offset": 202,
    "index": 12,
    "value": [
      "u16:2",
      "u8:0",
      "　近所なのに、なぜだか行く機会がなかった。山に行く時は\\n必ずパパ一人だったし、家族そろって出かけるというと、決\\nまって海というのが定番のコースだったから……。"
    ]
  },
  {
    "op": "41",
    "offset": 365,
    "index": 13,
    "value": [
      "u16:3",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 376,
    "index": 14,
    "value": [
      "u16:4",
      "u8:0",
      "　また──約束をしてしまった。"
    ]
  },
  {
    "op": "41",
    "offset": 411,
    "index": 15,
    "value": [
      "u16:5",
      "u8:0",
      "　本当に今度で終わりにするつもりだったのに。"
    ]
  },
  {
    "op": "41",
    "offset": 460,
    "index": 16,
    "value": [
      "u16:6",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 471,
    "index": 17,
    "value": [
      "u16:7",
      "u8:0",
      "　からかいたかったわけじゃない。"
    ]
  },
  {
    "op": "41",
    "offset": 508,
    "index": 18,
    "value": [
      "u16:8",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 519,
    "index": 19,
    "value": [
      "u16:9",
      "u8:0",
      "　求め──られたかったから？"
    ]
  },
  {
    "op": "41",
    "offset": 552,
    "index": 20,
    "value": [
      "u16:10",
      "u8:0",
      "　復讐？"
    ]
  },
  {
    "op": "41",
    "offset": 565,
    "index": 21,
    "value": [
      "u16:11",
      "u8:0",
      "　さんざんじらして振るため？"
