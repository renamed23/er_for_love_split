      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1915.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1560,
    "index": 52,
    "value": [
      "u16:25",
      "u8:0",
      "u8:0",
      "エレナ",
      "「一応、一通りつくれるわよ」"
    ]
  },
  {
    "op": "42",
    "offset": 1601,
    "index": 53,
    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "花丸",
      "「今度教えてよ。おれ、お菓子だめなんだ。煮物とかは平気\\n　なんだけど」"
    ]
  },
  {
    "op": "23",
    "offset": 1682,
    "index": 54,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1916.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1701,
    "index": 55,
    "value": [
      "u16:27",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あなた、男のくせに変わってるわね」"
    ]
  },
  {
    "op": "42",
    "offset": 1750,
    "index": 56,
    "value": [
      "u16:28",
      "u8:0",
      "u8:0",
      "花丸",
