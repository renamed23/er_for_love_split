    "op": "42",
    "offset": 2536,
    "index": 80,
    "value": [
      "u16:44",
      "u8:0",
      "u8:0",
      "エレナ",
      "「いいとは言ってないわよ」"
    ]
  },
  {
    "op": "42",
    "offset": 2575,
    "index": 81,
    "value": [
      "u16:45",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれはエレナさんがお姉さんでもいいよ」"
    ]
  },
  {
    "op": "23",
    "offset": 2626,
    "index": 82,
    "value": [
      "u8:0",
      "u16:65535",
