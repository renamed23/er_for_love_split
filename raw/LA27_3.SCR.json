    "index": 70,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1921.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2215,
    "index": 71,
    "value": [
      "u16:38",
      "u8:0",
      "u8:0",
      "エレナ",
      "「別に。ママが決めることだし」"
    ]
  },
  {
    "op": "42",
    "offset": 2258,
    "index": 72,
    "value": [
      "u16:39",
      "u8:0",
      "u8:0",
      "花丸",
      "「それ、風丸と同じ台詞」"
    ]
  },
  {
    "op": "23",
