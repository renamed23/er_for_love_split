    "value": [
      "u16:19",
      "u8:0",
      "u8:0",
      "エレナ",
      "「結構よ。虫酸が走るわ」"
    ]
  },
  {
    "op": "41",
    "offset": 1280,
    "index": 44,
    "value": [
      "u16:20",
      "u8:0",
      "　確かに風丸の言う通り、毒舌だ。"
