    "offset": 2417,
    "index": 77,
    "value": [
      "u16:42",
      "u8:0",
      "u8:0",
      "エレナ",
      "「わたしは別に反対も賛成もしない」"
    ]
  },
  {
    "op": "42",
    "offset": 2464,
    "index": 78,
    "value": [
      "u16:43",
      "u8:0",
      "u8:0",
      "花丸",
      "「じゃ、おれが弟でもいいってことなのかな」"
    ]
  },
  {
    "op": "23",
