    "value": [
      "u16:23",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あなたも上手なんですってね」"
    ]
  },
  {
    "op": "42",
    "offset": 1492,
    "index": 50,
    "value": [
      "u16:24",
      "u8:0",
      "u8:0",
      "花丸",
