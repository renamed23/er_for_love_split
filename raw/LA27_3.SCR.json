    "value": [
      "u16:21",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ママのこと、どう？」"
    ]
  },
  {
    "op": "42",
    "offset": 1371,
    "index": 47,
    "value": [
      "u16:22",
      "u8:0",
      "u8:0",
      "花丸",
      "「いいお母さんだと思うよ。料理も上手みたいだし」"
    ]
  },
  {
