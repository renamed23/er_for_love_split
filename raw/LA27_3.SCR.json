    "index": 73,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1922.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2312,
    "index": 74,
    "value": [
      "u16:40",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あいつもそう言ったの」"
    ]
  },
  {
    "op": "42",
    "offset": 2349,
    "index": 75,
    "value": [
      "u16:41",
      "u8:0",
      "u8:0",
      "花丸",
      "「風丸、放任主義だから。個人主義だし」"
    ]
  },
