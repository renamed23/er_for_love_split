    ]
  },
  {
    "op": "42",
    "offset": 1012,
    "index": 40,
    "value": [
      "u16:17",
      "u8:0",
      "u8:0",
      "エレナ",
      "「わたし幾つだと思ってるの？　子供じゃあるまいし、いき\\n　なりパパなんて呼べるわけないでしょ。あなたのことだっ\\n　て、弟だなんて──」"
    ]
  },
  {
    "op": "42",
    "offset": 1159,
    "index": 41,
    "value": [
      "u16:18",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれはいつでも姉さんと呼べるけどな。呼んでやろうか」"
    ]
  },
  {
    "op": "23",
    "offset": 1224,
    "index": 42,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1912.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1243,
