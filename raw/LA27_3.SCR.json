      "u16:29",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ふ～ん」"
    ]
  },
  {
    "op": "41",
    "offset": 1843,
    "index": 59,
    "value": [
      "u16:30",
      "u8:0",
      "　エレナさんがちらりと外を見る。"
    ]
  },
