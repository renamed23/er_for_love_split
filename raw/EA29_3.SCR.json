      "u16:5",
      "u8:0",
      "u8:0",
      "エレナ",
      "「お弁当作ってきたの」"
    ]
  },
  {
    "op": "41",
    "offset": 419,
    "index": 24,
    "value": [
      "u16:6",
      "u8:0",
      "　言ってエレナさんがお弁当の包みを取り出した。"
    ]
  },
  {
    "op": "49",
    "offset": 470,
    "index": 25,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
