    "value": [
      "u16:94",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あるよ。感じ悪い人だった」"
    ]
  },
  {
    "op": "42",
    "offset": 5954,
    "index": 190,
    "value": [
      "u16:95",
      "u8:0",
      "u8:0",
      "花丸",
      "「そうかな。おれ会った時はそんな感じしなかったけどな。\\n　ちょっと口調はきついけど」"
    ]
  },
  {
