      "u16:15",
      "u8:0",
      "u8:0",
      "ルナ",
      "「わたしがいやとか言えることじゃないもん」"
    ]
  },
  {
    "op": "41",
    "offset": 1034,
    "index": 48,
    "value": [
      "u16:16",
      "u8:0",
      "　答えを回避したけれど、いやそうな感じだった。"
    ]
  },
