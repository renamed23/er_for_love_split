    "value": [
      "u16:17",
      "u8:0",
      "u8:0",
      "ルナ",
      "「風丸お兄ちゃん、どうしていきなりうんとか言い出しちゃっ\\n　たんだろ」"
    ]
  },
  {
    "op": "42",
    "offset": 1185,
