      "u16:22",
      "u8:0",
      "u8:0",
      "ルナ",
      "「知らない親戚が……増えちゃったな……」"
    ]
  },
  {
    "op": "41",
    "offset": 1429,
    "index": 57,
    "value": [
      "u16:23",
      "u8:0",
