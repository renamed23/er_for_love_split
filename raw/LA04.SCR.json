  {
    "op": "41",
    "offset": 64,
    "index": 8,
    "value": [
      "u16:0",
      "u8:0",
      "　お兄ちゃんがいなくなると、魔法のマッチは消えてしまっ\\nた。残ったのは、ひとりという冷たさだけ。"
    ]
  },
  {
    "op": "49",
    "offset": 165,
    "index": 9,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 169,
    "index": 10,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 173,
    "index": 11,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B022BL"
    ]
  },
  {
    "op": "4A",
