    "value": [
      "u16:24",
      "u8:0",
      "u8:0",
      "鮎川",
      "「食べるもの食べてる？」"
    ]
  },
  {
    "op": "23",
    "offset": 1910,
    "index": 46,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0635.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1929,
    "index": 47,
    "value": [
      "u16:25",
      "u8:0",
      "u8:0",
      "ルナ",
      "「わたし、いい加減子供じゃありませんっ」"
    ]
  },
  {
    "op": "23",
    "offset": 1980,
    "index": 48,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "mot_0004.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1999,
    "index": 49,
    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "鮎川",
      "「何、その言い方？」"
    ]
  },
  {
    "op": "23",
    "offset": 2030,
    "index": 50,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0636.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2049,
    "index": 51,
    "value": [
      "u16:27",
      "u8:0",
      "u8:0",
      "ルナ",
      "「うるさいなあ、こっちは勉強してんだから邪魔しないでよ」"
    ]
  },
  {
    "op": "23",
    "offset": 2116,
    "index": 52,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "mot_0005.ogg"
    ]
  },
  {
    "op": "42",
