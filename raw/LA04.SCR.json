    "index": 53,
    "value": [
      "u16:28",
      "u8:0",
      "u8:0",
      "鮎川",
      "「そう……それはごめんなさい」"
    ]
  },
  {
    "op": "23",
    "offset": 2176,
    "index": 54,
    "value": [
      "u8:0",
      "u16:65535",
