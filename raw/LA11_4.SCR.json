    "index": 116,
    "value": [
      "u16:72",
      "u8:0",
      "u8:0",
      "ルナ",
      "「くす。またしてあげるね」"
    ]
  },
  {
    "op": "41",
    "offset": 5769,
    "index": 117,
    "value": [
      "u16:73",
      "u8:0",
      "　ルナは愛情たっぷりに微笑んでみせた。"
    ]
