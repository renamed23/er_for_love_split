    "offset": 5544,
    "index": 110,
    "value": [
      "u16:68",
      "u8:0",
      "u8:0",
      "ルナ",
      "「はあ……凄い……なんだか泥遊びぃ」"
    ]
  },
  {
    "op": "41",
    "offset": 5591,
    "index": 111,
    "value": [
      "u16:69",
      "u8:0",
      "　ルナが笑う。"
    ]
  },
  {
    "op": "23",
    "offset": 5610,
    "index": 112,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
