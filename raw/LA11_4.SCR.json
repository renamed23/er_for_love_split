    "index": 113,
    "value": [
      "u16:70",
      "u8:0",
      "u8:0",
      "ルナ",
      "「気持ちよかった？」"
    ]
  },
  {
    "op": "42",
    "offset": 5660,
    "index": 114,
    "value": [
      "u16:71",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん……ルナのオッパイ……凄くよかった」"
    ]
  },
  {
    "op": "23",
    "offset": 5713,
    "index": 115,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
