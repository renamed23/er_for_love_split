    "value": [
      "u16:12",
      "u8:0",
      "　いっしょに合格発表を見に来ていた風丸が隣に並んでいた。"
    ]
  },
  {
    "op": "42",
    "offset": 1008,
    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "風丸",
      "「青山でもいたのか？」"
    ]
  },
  {
    "op": "42",
    "offset": 1041,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "花丸",
      "「え……いや、別に」"
    ]
  },
  {
    "op": "41",
    "offset": 1072,
    "value": [
      "u16:15",
      "u8:0",
      "　風丸がおれの見ていた方を向いた。"
    ]
  },
  {
    "op": "42",
    "offset": 1111,
    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "風丸",
      "「あれ？　北条先輩──」"
    ]
  },
  {
    "op": "42",
    "offset": 1146,
    "value": [
      "u16:17",
      "u8:0",
      "u8:0",
      "花丸",
      "「知り合い？」"
    ]
  },
  {
    "op": "41",
    "offset": 1171,
    "value": [
      "u16:18",
      "u8:0",
      "　風丸は、少し複雑な表情を浮かべ、口を開いた。"
    ]
  },
  {
    "op": "42",
