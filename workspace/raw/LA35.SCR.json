    "value": [
      "u16:70",
      "u8:0",
      "u8:0",
      "鮎川",
      "「──あなたたち、まさか付き合ってるの？」"
    ]
  },
  {
    "op": "41",
    "offset": 4291,
    "value": [
      "u16:71",
      "u8:0",
