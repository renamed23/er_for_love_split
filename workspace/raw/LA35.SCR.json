      "u16:0",
      "u8:0",
      "　夢を──"
    ]
  },
  {
    "op": "41",
    "offset": 37,
    "value": [
      "u16:1",
      "u8:0",
      "　──見た。"
    ]
  },
  {
    "op": "41",
    "offset": 54,
    "value": [
      "u16:2",
      "u8:0",
      "　青い、空の夢だ。"
    ]
  },
  {
    "op": "41",
    "offset": 77,
    "value": [
      "u16:3",
      "u8:0",
      "　二浪が決まった時に見た空。"
    ]
  },
  {
    "op": "41",
    "offset": 110,
    "value": [
      "u16:4",
      "u8:0",
      "　はかなくて、切なくて、寝転がった自分の顔を、目尻から\\n耳にかけて涙が流れていった。"
    ]
  },
  {
    "op": "21",
