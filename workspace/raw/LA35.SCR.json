    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "青山",
      "「ルナちゃん、来てたぞ」"
    ]
  },
  {
    "op": "42",
    "offset": 627,
    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "花丸",
      "「いつ」"
    ]
  },
  {
    "op": "42",
    "offset": 646,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "青山",
      "「さっき。帰っちゃったけど。おまえに会ってたのかと思っ\\n　た」"
    ]
  },
  {
    "op": "42",
    "offset": 719,
    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "花丸",
      "「いや、会ってないけど」"
    ]
  },
  {
    "op": "42",
    "offset": 754,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "青山",
      "「そう……」"
    ]
  },
  {
    "op": "41",
    "offset": 777,
    "value": [
      "u16:15",
      "u8:0",
      "　どういうことだろう。"
    ]
  },
  {
    "op": "42",
    "offset": 804,
    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "青山",
      "「おまえ、飯食った？」"
    ]
  },
  {
    "op": "42",
