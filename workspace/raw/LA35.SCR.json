    "offset": 4562,
    "value": [
      "u16:76",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ちゃんと……勉強してたもん……」"
    ]
  },
  {
    "op": "23",
    "offset": 4607,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "mot_0037.ogg"
    ]
  },
  {
