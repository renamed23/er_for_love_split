      "u16:20",
      "u8:0",
      "u8:0",
      "ルナ",
      "「個人的理由って？」"
    ]
  },
  {
    "op": "41",
    "offset": 1202,
    "value": [
      "u16:21",
      "u8:0",
      "　樹里さんは笑っただけで答えてくれなかった。"
    ]
  },
