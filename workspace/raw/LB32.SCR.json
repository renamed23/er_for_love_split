      "u16:51",
      "u8:0",
      "u8:0",
      "ルナ",
      "「遠いところ」"
    ]
  },
  {
    "op": "42",
    "offset": 3356,
    "value": [
      "u16:52",
      "u8:0",
      "u8:0",
      "英一郎",
      "「遠いところ？　それって、あっちの世界じゃないよね」"
    ]
  },
  {
    "op": "23",
