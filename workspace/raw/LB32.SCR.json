    "value": [
      "u16:53",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あはは、違うよ～」"
    ]
  },
  {
    "op": "42",
    "offset": 3471,
    "value": [
      "u16:54",
      "u8:0",
      "u8:0",
      "英一郎",
      "「じゃ、どこ？　自分の行きたいところ、言っていいよ」"
    ]
  },
  {
    "op": "23",
    "offset": 3536,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_2058.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 3555,
    "value": [
      "u16:55",
      "u8:0",
      "u8:0",
      "ルナ",
      "「じゃ、東京。まるきゅー行ってみたい～」"
    ]
  },
  {
    "op": "42",
    "offset": 3606,
    "value": [
      "u16:56",
      "u8:0",
      "u8:0",
      "英一郎",
      "「いいよ」"
    ]
  },
  {
    "op": "49",
    "offset": 3629,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 3633,
    "value": [
      "u8:1",
      "u8:0",
