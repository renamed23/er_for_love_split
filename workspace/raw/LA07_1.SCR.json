    "value": [
      "u16:102",
      "u8:0",
      "u8:0",
      "青山",
      "「おれのどこが悪いんだ～～っ！」"
    ]
  },
  {
    "op": "42",
    "offset": 5364,
    "value": [
      "u16:103",
      "u8:0",
      "u8:0",
      "花丸",
      "「はあ？　お、落ち着けえ」"
    ]
  },
  {
    "op": "42",
    "offset": 5401,
    "value": [
      "u16:104",
      "u8:0",
      "u8:0",
      "青山",
      "「カルメンちゃん、絶対おれ、避けてたよな？　な、避けて\\n　たよな？　なんでだ？　やっぱりか？」"
    ]
  },
  {
    "op": "42",
    "offset": 5506,
    "value": [
      "u16:105",
      "u8:0",
      "u8:0",
      "花丸",
      "「やっぱりかって、何だよ」"
    ]
  },
  {
    "op": "42",
    "offset": 5543,
    "value": [
      "u16:106",
      "u8:0",
      "u8:0",
      "青山",
      "「おれ、あの子、おまえのこと好きなんじゃないかって思っ\\n　て……」"
    ]
  },
  {
    "op": "41",
    "offset": 5620,
    "value": [
      "u16:107",
      "u8:0",
      "　どきりとした。"
    ]
  },
  {
    "op": "41",
    "offset": 5641,
    "value": [
      "u16:108",
      "u8:0",
      "　なかなか、鋭いじゃないか。"
    ]
  },
  {
    "op": "42",
    "offset": 5674,
    "value": [
      "u16:109",
      "u8:0",
      "u8:0",
      "青山",
