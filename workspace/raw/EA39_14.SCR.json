  },
  {
    "op": "42",
    "offset": 998,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ンフン……アフン……ンフン……ちゅぽちゅぽちゅぽ……\\n　ちゅううっ……ちゅぽちゅぽちゅぽ……ちゅるるる……」"
    ]
  },
  {
    "op": "41",
    "offset": 1121,
    "value": [
      "u16:11",
      "u8:0",
      "　アフン、ンフンと雰囲気たっぷり妖艶な息を弾ませながら、\\n美味しそうにおれのものをしゃぶってゆく。"
    ]
  },
  {
    "op": "23",
    "offset": 1224,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0941.ogg"
