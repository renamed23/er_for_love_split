    ]
  },
  {
    "op": "41",
    "offset": 1589,
    "value": [
      "u16:15",
      "u8:0",
      "《次は、南野台》"
    ]
  },
  {
    "op": "41",
    "offset": 1610,
    "value": [
      "u16:16",
      "u8:0",
