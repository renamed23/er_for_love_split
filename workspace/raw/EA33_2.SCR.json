  },
  {
    "op": "41",
    "offset": 654,
    "value": [
      "u16:8",
      "u8:0",
      "　怖い顔をして、"
    ]
  },
  {
    "op": "49",
    "offset": 675,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
