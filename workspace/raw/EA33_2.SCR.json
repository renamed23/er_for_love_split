    ]
  },
  {
    "op": "41",
    "offset": 703,
    "value": [
      "u16:9",
      "u8:0",
      "　去っていってしまった。"
    ]
  },
  {
    "op": "42",
    "offset": 732,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "青山",
      "「ビンゴ～～～っ！　またあのかわい子ちゃんに会えるなん\\n　て、おれ、幸せ～～っ！」"
    ]
  },
  {
    "op": "42",
    "offset": 825,
    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれは──不幸だ」"
    ]
  },
  {
