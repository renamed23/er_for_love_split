      "u8:0",
      "u8:0",
      "エレナ",
      "「どうしてあなたに答えなきゃいけないわけ？　弟にも報告\\n　義務あるわけ？　ばっかじゃないの」"
    ]
  },
  {
    "op": "42",
    "offset": 2044,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "風丸",
      "「──一言、言っていいですか」"
    ]
  },
  {
    "op": "42",
    "offset": 2085,
    "value": [
      "u16:34",
      "u8:0",
      "u8:0",
      "風丸",
      "「そんな言い方してたら、誰も好きになってくれる人、出て\\n　きませんよ」"
    ]
  },
  {
    "op": "23",
    "offset": 2166,
    "value": [
