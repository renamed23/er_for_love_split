    ]
  },
  {
    "op": "41",
    "offset": 2412,
    "value": [
      "u16:39",
      "u8:0",
      "　あなたに関係ないでしょ。"
    ]
  },
  {
    "op": "41",
    "offset": 2443,
    "value": [
      "u16:40",
      "u8:0",
      "　背中に向かってわたしは胸のなかで言い放った。"
    ]
  },
  {
    "op": "41",
    "offset": 2494,
    "value": [
      "u16:41",
      "u8:0",
      "　だから、あなたなんか大っ嫌いなのよ。"
    ]
  },
  {
    "op": "49",
    "offset": 2537,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
