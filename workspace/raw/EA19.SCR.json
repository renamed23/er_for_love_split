    "value": [
      "u16:31",
      "u8:0",
      "　早朝、六時。"
    ]
  },
  {
    "op": "41",
    "offset": 1749,
    "value": [
      "u16:32",
      "u8:0",
      "　親父と風丸の朝御飯だけ作って、二階に上がった。"
    ]
  },
  {
    "op": "49",
    "offset": 1802,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
