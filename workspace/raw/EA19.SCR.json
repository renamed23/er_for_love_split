    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 2712,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 2716,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B003BL"
    ]
  },
  {
    "op": "48",
    "offset": 2733,
    "value": [
      "u8:1",
      "u16:224",
      "u16:0",
      "u32:0",
      "u8:0",
      "a804_1b"
    ]
  },
  {
    "op": "4A",
    "offset": 2752,
    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "42",
    "offset": 2757,
    "value": [
      "u16:48",
      "u8:0",
      "u8:0",
      "親父",
      "「なんだ。まだ起きてたのか」"
    ]
  },
  {
    "op": "41",
    "offset": 2796,
    "value": [
      "u16:49",
      "u8:0",
      "　時計は１時を回っていた。"
    ]
  },
  {
    "op": "42",
    "offset": 2827,
    "value": [
      "u16:50",
      "u8:0",
      "u8:0",
      "花丸",
      "「ずいぶん遅かったな」"
    ]
  },
  {
    "op": "42",
    "offset": 2860,
    "value": [
      "u16:51",
      "u8:0",
      "u8:0",
      "親父",
      "「少しな」"
    ]
  },
  {
    "op": "41",
    "offset": 2881,
    "value": [
      "u16:52",
      "u8:0",
      "　一旦、会話が途切れる。"
    ]
  },
  {
    "op": "42",
    "offset": 2910,
    "value": [
      "u16:53",
      "u8:0",
      "u8:0",
      "親父",
      "「眠れないのか」"
    ]
  },
  {
    "op": "42",
    "offset": 2937,
    "value": [
      "u16:54",
      "u8:0",
      "u8:0",
      "花丸",
      "「別に」"
    ]
  },
  {
    "op": "42",
    "offset": 2956,
    "value": [
      "u16:55",
      "u8:0",
      "u8:0",
      "親父",
      "「仕事で眠れないってものは、なかなかないもんでな。だい\\n　たい眠れない時は、女だ」"
    ]
  },
  {
    "op": "41",
    "offset": 3049,
    "value": [
      "u16:56",
      "u8:0",
      "　おれは黙って親父を見た。"
    ]
  },
  {
    "op": "42",
    "offset": 3080,
    "value": [
      "u16:57",
      "u8:0",
      "u8:0",
      "親父",
      "「学生ン時は、父さんもそうだったな。相手の子が好きなの\\n　か好きでないのかとか、それ以前に自分が本当に好きなの\\n　かどうかとか考えたりしてな」"
    ]
  },
  {
    "op": "42",
    "offset": 3233,
    "value": [
      "u16:58",
      "u8:0",
      "u8:0",
      "親父",
      "「なぜか、好きということに理由を求めてしまう。若い頃っ\\n　てのは、要するに頭でっかちだったんだな」"
    ]
  },
  {
    "op": "42",
    "offset": 3342,
    "value": [
      "u16:59",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれが頭でっかちだって言いたいのか」"
    ]
  },
  {
    "op": "42",
    "offset": 3391,
    "value": [
      "u16:60",
      "u8:0",
      "u8:0",
      "親父",
      "「父さんがそうだったんだ。母さんとの時もな」"
    ]
  },
  {
    "op": "42",
    "offset": 3446,
    "value": [
      "u16:61",
      "u8:0",
      "u8:0",
      "花丸",
      "「──」"
    ]
  },
  {
    "op": "42",
    "offset": 3465,
    "value": [
      "u16:62",
      "u8:0",
      "u8:0",
      "親父",
      "「馬鹿なことばかり考えたよ。どこが好きなのかな、とかな。\\n　それがはっきりしていないと、本当に好きじゃない気がし\\n　てな」"
    ]
  },
  {
    "op": "42",
    "offset": 3598,
    "value": [
      "u16:63",
      "u8:0",
      "u8:0",
      "親父",
      "「けどな。好きに理由なんてないんだ。どこが好きなのかわ\\n　かんない、なぜ好きなのかわかんない。それが、惚れてるっ\\n　て証拠なんだ」"
    ]
  },
  {
    "op": "49",
    "offset": 3739,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 3743,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 3747,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B003BL"
    ]
  },
  {
    "op": "48",
    "offset": 3764,
    "value": [
      "u8:1",
      "u16:224",
      "u16:0",
      "u32:0",
      "u8:0",
      "a804_1c"
    ]
  },
  {
    "op": "4A",
    "offset": 3783,
    "value": [
      "bytes:19 F4 01 00"
    ]
  },
  {
    "op": "41",
    "offset": 3788,
    "value": [
      "u16:64",
      "u8:0",
      "　親父はにやっと笑った。"
    ]
  },
  {
    "op": "42",
    "offset": 3817,
    "value": [
      "u16:65",
      "u8:0",
      "u8:0",
      "親父",
      "「おまえもそういう顔をしてるぞ」"
    ]
  },
  {
    "op": "42",
    "offset": 3860,
    "value": [
      "u16:66",
      "u8:0",
      "u8:0",
      "花丸",
      "「何も言ってないぞ、おれは」"
    ]
  },
  {
    "op": "42",
    "offset": 3899,
    "value": [
      "u16:67",
      "u8:0",
      "u8:0",
      "親父",
      "「おまえが友達づきあいで悩むたちか？　勉強？　就職？\\n　女しかないだろ」"
    ]
  },
  {
    "op": "42",
    "offset": 3982,
    "value": [
      "u16:68",
      "u8:0",
      "u8:0",
      "花丸",
      "「違うかもしれないぞ」"
    ]
  },
  {
    "op": "42",
    "offset": 4015,
    "value": [
      "u16:69",
      "u8:0",
      "u8:0",
      "親父",
      "「おまえは風丸と違ってわかりやすいからな」"
    ]
  },
  {
    "op": "49",
    "offset": 4068,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 4072,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 4076,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B003BL"
    ]
  },
  {
    "op": "4A",
    "offset": 4093,
    "value": [
      "bytes:19 F4 01 00"
    ]
  },
  {
    "op": "41",
    "offset": 4098,
    "value": [
      "u16:70",
      "u8:0",
      "　親父はにっと笑ってリビングを出ていった。やがて、ドア\\nの閉まる音が聞こえた。"
    ]
  },
  {
    "op": "49",
    "offset": 4181,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 4185,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 4189,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B008DARK"
    ]
  },
  {
    "op": "4A",
    "offset": 4208,
    "value": [
      "bytes:0D F4 01 00"
    ]
  },
  {
    "op": "41",
    "offset": 4213,
    "value": [
      "u16:71",
      "u8:0",
      "　部屋に上がって電気を消した。"
    ]
  },
  {
    "op": "41",
    "offset": 4248,
    "value": [
      "u16:72",
      "u8:0",
      "　でも──"
    ]
  },
  {
    "op": "41",
    "offset": 4263,
    "value": [
      "u16:73",
      "u8:0",
      "　眠れない。"
    ]
  },
  {
    "op": "41",
    "offset": 4280,
    "value": [
      "u16:74",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "49",
    "offset": 4291,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 4295,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 4299,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B006BL"
    ]
  },
  {
    "op": "4A",
    "offset": 4316,
    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 4321,
    "value": [
      "u16:75",
      "u8:0",
      "　ベランダに出た。空を見上げた。"
    ]
  },
  {
    "op": "41",
    "offset": 4358,
    "value": [
      "u16:76",
      "u8:0",
      "　ふいに、エレナさんの台詞が蘇った。"
    ]
  },
  {
    "op": "41",
    "offset": 4399,
    "value": [
      "u16:77",
      "u8:0",
      "《人って、ほとんど猫よね》"
    ]
  },
  {
    "op": "41",
    "offset": 4430,
    "value": [
      "u16:78",
      "u8:0",
      "《一度いやな目に遭わせちゃうと、二度とその人は近づかな\\nい》"
    ]
  },
  {
    "op": "41",
    "offset": 4495,
    "value": [
      "u16:79",
      "u8:0",
      "　息を──"
    ]
  },
  {
    "op": "41",
    "offset": 4510,
    "value": [
      "u16:80",
      "u8:0",
      "　──呑んだ。"
    ]
  },
  {
    "op": "41",
    "offset": 4529,
    "value": [
      "u16:81",
      "u8:0",
      "　何をしてるんだ、おれは。"
    ]
  },
  {
    "op": "41",
    "offset": 4560,
    "value": [
      "u16:82",
      "u8:0",
      "　ふと目が覚めた。"
    ]
  },
  {
    "op": "41",
    "offset": 4583,
    "value": [
      "u16:83",
      "u8:0",
      "　何を、おれ被害者面してるんだ？　落ち込んでる場合じゃ\\nないだろ。"
    ]
  },
  {
    "op": "41",
    "offset": 4654,
    "value": [
      "u16:84",
      "u8:0",
      "　このままじゃ、このままじゃ、おれも──"
    ]
  },
  {
    "op": "41",
    "offset": 4699,
    "value": [
      "u16:85",
      "u8:0",
      "《そう言って、みんな猫になるのよ》"
    ]
  },
  {
    "op": "41",
    "offset": 4738,
    "value": [
      "u16:86",
      "u8:0",
      "　──ただの、猫だ。"
    ]
  },
