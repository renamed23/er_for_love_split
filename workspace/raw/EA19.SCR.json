    "value": [
      "u16:88",
      "u8:0",
      "u8:0",
      "樹里",
      "「どうしたの？　心配してたんだよ」"
    ]
  },
  {
    "op": "42",
    "offset": 5061,
    "value": [
      "u16:89",
      "u8:0",
      "u8:0",
      "花丸",
      "「どうもレーンに呼ばれてる気がして」"
    ]
  },
  {
    "op": "41",
    "offset": 5108,
    "value": [
      "u16:90",
      "u8:0",
      "　照れ隠しで冗談を言う。"
    ]
  },
  {
    "op": "41",
    "offset": 5137,
    "value": [
      "u16:91",
      "u8:0",
      "　水曜日。雨だったけれど、思い切っておれはボウリング場\\nに顔を出してみた。"
    ]
  },
  {
    "op": "42",
    "offset": 5216,
    "value": [
      "u16:92",
      "u8:0",
      "u8:0",
      "花丸",
      "「青山は？」"
    ]
  },
  {
    "op": "23",
    "offset": 5239,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0069.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 5258,
    "value": [
      "u16:93",
      "u8:0",
      "u8:0",
      "樹里",
      "「多分、今日も遅刻」"
    ]
  },
  {
    "op": "41",
    "offset": 5289,
    "value": [
      "u16:94",
      "u8:0",
      "　おれは辺りを見回した。"
    ]
  },
  {
    "op": "41",
    "offset": 5318,
    "value": [
      "u16:95",
      "u8:0",
      "　エレナさんが──"
    ]
  },
  {
    "op": "41",
    "offset": 5341,
    "value": [
      "u16:96",
      "u8:0",
