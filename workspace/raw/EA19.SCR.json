  },
  {
    "op": "41",
    "offset": 2655,
    "value": [
      "u16:47",
      "u8:0",
      "　廊下を通って自分の部屋へ行くようだ。"
    ]
  },
  {
    "op": "21",
    "offset": 2698,
    "value": [
      "u8:0",
      "u16:0",
      "BGM10"
    ]
  },
  {
