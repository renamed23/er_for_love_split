    "value": [
      "u16:13",
      "u8:0",
      "　帰って来てから、自分の部屋でＴＶを見た。"
    ]
  },
  {
    "op": "41",
    "offset": 825,
    "value": [
      "u16:14",
      "u8:0",
      "　エレナさんの膝枕で、ときおりうとうとしながら。"
    ]
  },
  {
    "op": "41",
    "offset": 878,
    "value": [
      "u16:15",
      "u8:0",
