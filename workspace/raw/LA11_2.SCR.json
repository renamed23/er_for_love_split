    "value": [
      "u16:17",
      "u8:0",
      "u8:0",
      "ルナ",
      "「……いや……」"
    ]
  },
  {
    "op": "41",
    "offset": 1374,
    "value": [
      "u16:18",
      "u8:0",
      "　小さな声でルナが言う。"
