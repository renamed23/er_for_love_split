    ]
  },
  {
    "op": "42",
    "offset": 119,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "風丸",
      "「いや、そうかなとは思ったけど、ほんとにそうだと思わな\\n　かった」"
