  {
    "op": "42",
    "offset": 196,
    "value": [
      "u16:4",
      "u8:0",
      "u8:0",
      "花丸",
      "「なんか、答え矛盾してねえ？」"
    ]
  },
  {
    "op": "42",
    "offset": 237,
    "value": [
      "u16:5",
      "u8:0",
      "u8:0",
      "風丸",
      "「いや、いつ付き合い出してもおかしくないなとは思ってた\\n　けど」"
    ]
  },
  {
    "op": "41",
    "offset": 312,
    "value": [
      "u16:6",
      "u8:0",
