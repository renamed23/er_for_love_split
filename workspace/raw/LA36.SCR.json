    "value": [
      "u16:33",
      "u8:0",
      "　１１月５日、火曜日。"
    ]
  },
  {
    "op": "49",
    "offset": 2069,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
