    ]
  },
  {
    "op": "23",
    "offset": 465,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1014.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 484,
    "value": [
      "u16:5",
      "u8:0",
      "u8:0",
      "ルナ",
      "「えへ、よかった……ぴちゃ……ぴちゃぴちゃ……ちゅぷ…\\n　…ぴちゃぴちゃ……ぺろぺろぺろ……」"
    ]
  },
  {
    "op": "41",
    "offset": 589,
    "value": [
      "u16:6",
      "u8:0",
      "　ルナが丁寧に舌を亀頭に押し当てて舐めあげる。"
    ]
  },
  {
    "op": "23",
    "offset": 640,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1015.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 659,
    "value": [
      "u16:7",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ンフン……ちゅぷ……ぴちゃぴちゃぴちゃ……ンフン……\\n　ちゅぷ……れろれろれろ……」"
    ]
  },
  {
    "op": "42",
    "offset": 756,
    "value": [
      "u16:8",
      "u8:0",
      "u8:0",
