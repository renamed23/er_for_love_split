  {
    "op": "42",
    "offset": 1712,
    "value": [
      "u16:22",
      "u8:0",
      "u8:0",
      "花丸",
      "「うっ……ああ……ルナ……」"
    ]
  },
  {
    "op": "41",
    "offset": 1751,
    "value": [
      "u16:23",
      "u8:0",
      "　思わずルナの頭を抱え込む。"
    ]
  },
  {
    "op": "41",
    "offset": 1784,
    "value": [
      "u16:24",
      "u8:0",
      "　はじめはぎこちなかったルナも、だんだん自信を持ってき\\nたのか感覚がつかめてきたのか、積極的に舌を押し当ててね\\nぶりたててきた。"
    ]
  },
  {
    "op": "41",
    "offset": 1917,
    "value": [
      "u16:25",
      "u8:0",
      "　舌先を押し当ててくすぐるように舐めたかと思うと、舌全\\n体を押し当ててじゅる、じゅるっとしゃぶりたててくる。"
    ]
  },
  {
    "op": "42",
    "offset": 2030,
    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "花丸",
      "「る、ルナ……首振ってちゅぱちゅぱしてみて……」"
