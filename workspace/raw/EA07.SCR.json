  {
    "op": "41",
    "offset": 1147,
    "value": [
      "u16:22",
      "u8:0",
      "　電車は田舎のど真ん中を走っていた。"
    ]
  },
  {
    "op": "41",
    "offset": 1188,
    "value": [
      "u16:23",
      "u8:0",
      "　四人掛けの席に向かい合って彼女と二人。"
    ]
  },
  {
    "op": "41",
    "offset": 1233,
    "value": [
      "u16:24",
      "u8:0",
      "　開いた窓から流れ込む風が彼女の髪を吹き上げて、切ない\\n香りを吹きつける。"
    ]
  },
  {
    "op": "41",
    "offset": 1312,
    "value": [
      "u16:25",
      "u8:0",
      "　目指すは、武山線の終着駅、武山町。"
    ]
  },
  {
    "op": "41",
    "offset": 1353,
    "value": [
      "u16:26",
      "u8:0",
      "　人口３万の町だ。"
    ]
  },
  {
    "op": "41",
    "offset": 1376,
    "value": [
      "u16:27",
      "u8:0",
      "　文化と行政の中心地・山手市に住む人々にとっては、手頃\\nな田舎。子供の頃は、わざわざ風丸とカブトムシを取りに出\\nかけたものだ。"
    ]
  },
  {
    "op": "41",
    "offset": 1507,
    "value": [
      "u16:28",
      "u8:0",
      "　開け放たれた窓からは、汚れていない空気が入り込んでい\\nた。"
    ]
  },
  {
    "op": "41",
    "offset": 1572,
    "value": [
      "u16:29",
      "u8:0",
      "　出発してすぐは都会の町並みだったが、次第にアスファル\\nトとコンクリートが遠ざかり、今はほとんど田と畑だけになっ\\nていた。遠くには、標高千メートルの武山岳（ぶざんだけ）\\nが見える。"
    ]
  },
  {
    "op": "41",
    "offset": 1757,
    "value": [
      "u16:30",
      "u8:0",
      "　だだっぴろい田んぼのなかに、うずくまるでっかい人家。"
    ]
  },
  {
    "op": "41",
    "offset": 1816,
    "value": [
      "u16:31",
      "u8:0",
      "　だだっぴろい田んぼのなかに、突然居を構える工場。"
    ]
  },
  {
    "op": "41",
    "offset": 1871,
    "value": [
      "u16:32",
      "u8:0",
      "　県道とパチンコ店。"
    ]
  },
  {
    "op": "41",
    "offset": 1896,
    "value": [
      "u16:33",
      "u8:0",
      "　ガソリンスタンド。"
    ]
  },
  {
    "op": "41",
    "offset": 1921,
    "value": [
      "u16:34",
      "u8:0",
      "　延々とつづく電線。"
    ]
  },
  {
    "op": "41",
    "offset": 1946,
    "value": [
      "u16:35",
      "u8:0",
      "　そんなのを見ながら、ＪＲ武山（ぶざん）線は走ってゆく。"
    ]
  },
  {
    "op": "41",
    "offset": 2007,
    "value": [
      "u16:36",
      "u8:0",
      "　終着駅までは、あと半時間だ。"
    ]
  },
