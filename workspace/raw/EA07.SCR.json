      "u16:10",
      "u8:0",
      "　あれ？"
    ]
  },
  {
    "op": "41",
    "offset": 487,
    "value": [
      "u16:11",
      "u8:0",
      "　意外にも早く彼女は現れた。"
    ]
  },
  {
    "op": "41",
    "offset": 520,
    "value": [
      "u16:12",
      "u8:0",
      "　といっても、じゅうぶん遅刻はしているのだけれど、少し\\nびっくり。"
    ]
  },
  {
    "op": "41",
    "offset": 591,
    "value": [
      "u16:13",
      "u8:0",
      "　おまけに普段とは違う装いに、遅れてうれしさが込み上げ\\nてきた。"
    ]
  },
  {
    "op": "42",
    "offset": 660,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "花丸",
      "「今日はやけに早いじゃないか、ハニー」"
    ]
  },
  {
    "op": "41",
    "offset": 709,
    "value": [
      "u16:15",
      "u8:0",
      "　また思わず言葉がすべる。"
    ]
  },
  {
    "op": "23",
    "offset": 740,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
