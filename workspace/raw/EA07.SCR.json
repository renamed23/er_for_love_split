    ]
  },
  {
    "op": "42",
    "offset": 759,
    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "エレナ",
      "「何言ってんのよ、馬鹿」"
    ]
  },
  {
    "op": "41",
    "offset": 796,
    "value": [
      "u16:17",
      "u8:0",
      "　ははは……やはり。"
    ]
  },
  {
    "op": "49",
