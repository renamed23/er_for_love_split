    "op": "42",
    "offset": 2432,
    "value": [
      "u16:42",
      "u8:0",
      "u8:0",
      "花丸",
      "「じゃあ、そのカメラは何だ！」"
    ]
  },
  {
    "op": "42",
    "offset": 2473,
    "value": [
      "u16:43",
      "u8:0",
      "u8:0",
      "宗彦",
      "「か、彼女が撮ってほしいって言ったから──」"
    ]
  },
  {
    "op": "42",
    "offset": 2528,
    "value": [
      "u16:44",
      "u8:0",
      "u8:0",
      "花丸",
