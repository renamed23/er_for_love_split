  },
  {
    "op": "42",
    "offset": 4258,
    "value": [
      "u16:64",
      "u8:0",
      "u8:0",
      "エレナ",
      "「くすっ。なあに」"
    ]
  },
  {
    "op": "41",
    "offset": 4289,
    "value": [
      "u16:65",
      "u8:0",
      "　エレナさんが色っぽい目で見つめる。"
    ]
  },
  {
    "op": "41",
    "offset": 4330,
    "value": [
      "u16:66",
      "u8:0",
      "　つやつやと暗闇で濡れ輝く唇に、またドキッとする。"
    ]
  },
  {
    "op": "41",
    "offset": 4385,
    "value": [
      "u16:67",
      "u8:0",
      "　エレナさんの目が、少し大人の色を帯びていた。"
    ]
  },
  {
    "op": "23",
    "offset": 4436,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0291.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4455,
    "value": [
      "u16:68",
      "u8:0",
      "u8:0",
      "エレナ",
      "「キスしたい？」"
    ]
  },
  {
    "op": "41",
    "offset": 4484,
    "value": [
      "u16:69",
      "u8:0",
      "　ふいに近づいてきた。"
    ]
  },
  {
    "op": "41",
    "offset": 4511,
    "value": [
