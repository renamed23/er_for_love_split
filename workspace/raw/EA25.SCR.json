      "u8:0",
      "u8:0",
      "エレナ",
      "「くす。わたしも」"
    ]
  },
  {
    "op": "41",
    "offset": 3654,
    "value": [
      "u16:53",
      "u8:0",
      "　エレナさんは笑った。"
    ]
  },
  {
    "op": "41",
