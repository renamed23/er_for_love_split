  },
  {
    "op": "41",
    "offset": 2510,
    "value": [
      "u16:34",
      "u8:0",
      "　エレナさんの目が少し笑った。"
    ]
  },
  {
    "op": "23",
    "offset": 2545,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0280.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2564,
    "value": [
      "u16:35",
      "u8:0",
      "u8:0",
      "エレナ",
      "「今日は、送ってくれるんでしょ？」"
    ]
  },
  {
    "op": "41",
    "offset": 2611,
    "value": [
      "u16:36",
      "u8:0",
      "　ちょっと悪戯っぽい表情だった。"
    ]
  },
  {
    "op": "42",
    "offset": 2648,
    "value": [
      "u16:37",
      "u8:0",
      "u8:0",
      "花丸",
      "「送り狼になってほしい？」"
    ]
  },
  {
    "op": "23",
    "offset": 2685,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0281.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2704,
    "value": [
      "u16:38",
      "u8:0",
      "u8:0",
      "エレナ",
      "「お馬鹿さん。狼はいやよ」"
    ]
  },
  {
    "op": "41",
    "offset": 2743,
    "value": [
      "u16:39",
      "u8:0",
      "　言いながら目が笑っていた。"
    ]
  },
  {
    "op": "26",
    "offset": 2776,
    "value": [
      "u16:0"
    ]
  },
  {
    "op": "22",
