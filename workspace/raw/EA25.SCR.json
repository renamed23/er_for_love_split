  {
    "op": "42",
    "offset": 4089,
    "value": [
      "u16:60",
      "u8:0",
      "u8:0",
      "エレナ",
      "「今日はありがとう」"
    ]
  },
  {
    "op": "41",
    "offset": 4122,
    "value": [
      "u16:61",
      "u8:0",
      "　心なしか、唇が艶っぽく見える。"
    ]
  },
  {
    "op": "41",
    "offset": 4159,
    "value": [
      "u16:62",
      "u8:0",
      "　夜──だからか？"
    ]
  },
  {
    "op": "41",
    "offset": 4182,
    "value": [
      "u16:63",
      "u8:0",
      "　初めて、エレナさんをマンション近くまで送ったから？"
    ]
  },
  {
    "op": "23",
    "offset": 4239,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
