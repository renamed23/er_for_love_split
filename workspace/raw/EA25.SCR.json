    ]
  },
  {
    "op": "41",
    "offset": 2379,
    "value": [
      "u16:31",
      "u8:0",
      "　次は南野台だ。"
    ]
  },
  {
    "op": "23",
    "offset": 2400,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0279.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2419,
    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "エレナ",
      "「次ね」"
    ]
  },
  {
    "op": "42",
    "offset": 2440,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "花丸",
      "「そうだね」"
    ]
  },
  {
    "op": "49",
    "offset": 2463,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
