    "offset": 947,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "花丸",
      "「エレナさんのような高級品はおまえにはわからんのだよ」"
    ]
  },
  {
    "op": "42",
    "offset": 1012,
    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "宗彦",
      "「フン。蘭山大学の芋にそんなこと言われたくないね」"
