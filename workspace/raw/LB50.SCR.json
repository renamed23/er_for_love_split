    "offset": 1684,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "エレナ",
      "「そう」"
    ]
  },
  {
    "op": "42",
    "offset": 1705,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "花丸",
      "「……」"
    ]
  },
  {
    "op": "23",
