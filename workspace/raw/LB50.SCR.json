    ]
  },
  {
    "op": "41",
    "offset": 1139,
    "value": [
      "u16:18",
      "u8:0",
      "　初詣──。"
    ]
  },
  {
    "op": "41",
    "offset": 1156,
    "value": [
      "u16:19",
      "u8:0",
      "　親父たちと離れると、おれとエレナさんだけになった。"
    ]
  },
  {
    "op": "41",
    "offset": 1213,
    "value": [
      "u16:20",
      "u8:0",
      "　まわりに参拝客は満ちあふれているけれど、二人きりの世\\n界。"
    ]
  },
  {
    "op": "41",
    "offset": 1278,
    "value": [
      "u16:21",
      "u8:0",
      "　おれは、エレナさんの腕を引き寄せた。"
    ]
  },
  {
    "op": "41",
    "offset": 1321,
    "value": [
      "u16:22",
      "u8:0",
      "　二人で腕を組んだ。"
    ]
  },
  {
    "op": "49",
    "offset": 1346,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
