      "u16:23",
      "u8:0",
      "u8:0",
      "エレナ",
      "「馬鹿」"
    ]
  },
  {
    "op": "41",
    "offset": 1433,
    "value": [
      "u16:24",
      "u8:0",
      "　弱々しい声で言ったけれど、エレナさんはぎゅっと力をこ\\nめてきた。"
    ]
  },
  {
    "op": "41",
    "offset": 1504,
    "value": [
      "u16:25",
      "u8:0",
      "　思いは同じだった。"
    ]
  },
  {
    "op": "41",
    "offset": 1529,
    "value": [
      "u16:26",
      "u8:0",
      "　二人きりになれない時間が、加速させていた。"
    ]
  },
