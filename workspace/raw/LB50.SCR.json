    ]
  },
  {
    "op": "41",
    "offset": 1035,
    "value": [
      "u16:17",
      "u8:0",
      "　二人きりになる機会は、意外と早く現れた。"
    ]
  },
  {
    "op": "21",
    "offset": 1082,
    "value": [
      "u8:0",
      "u16:0",
      "BGM17"
    ]
  },
