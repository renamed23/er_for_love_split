    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ごめんね」"
    ]
  },
  {
    "op": "42",
    "offset": 1849,
    "value": [
      "u16:34",
      "u8:0",
      "u8:0",
      "花丸",
      "「エレナさんのせいじゃないよ」"
    ]
  },
  {
