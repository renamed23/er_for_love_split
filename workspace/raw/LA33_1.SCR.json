    "value": [
      "u16:38",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ううん……遅くなっちゃうから」"
    ]
  },
  {
    "op": "42",
    "offset": 2068,
    "value": [
      "u16:39",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん……」"
    ]
  },
  {
    "op": "41",
    "offset": 2091,
    "value": [
      "u16:40",
      "u8:0",
      "　もう時計は夜中の２時だった。"
    ]
  },
  {
    "op": "42",
    "offset": 2126,
    "value": [
      "u16:41",
      "u8:0",
      "u8:0",
      "花丸",
      "「次のセンター模試で６５０は行きたいな」"
    ]
  },
  {
