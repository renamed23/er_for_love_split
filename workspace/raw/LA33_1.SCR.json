  },
  {
    "op": "42",
    "offset": 2431,
    "value": [
      "u16:46",
      "u8:0",
      "u8:0",
      "ルナ",
      "「……私立、併願しないで国立一本で絞った方がいいかな」"
    ]
  },
  {
    "op": "42",
    "offset": 2496,
    "value": [
      "u16:47",
      "u8:0",
      "u8:0",
      "花丸",
      "「叔母さんがＯＫしてくれるといいけどな」"
    ]
  },
  {
    "op": "23",
    "offset": 2547,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1446.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2566,
    "value": [
      "u16:48",
      "u8:0",
      "u8:0",
      "ルナ",
      "「だめだよ、ママは。あの人、人の言うこと聞かないもん」"
    ]
  },
  {
    "op": "42",
    "offset": 2631,
    "value": [
      "u16:49",
      "u8:0",
      "u8:0",
      "花丸",
      "「けど、独り暮らしさせてくれたんだろ」"
    ]
  },
  {
    "op": "23",
    "offset": 2680,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1447.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2699,
    "value": [
      "u16:50",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あれはパパがいいって言ったからだもん。通学させたら逆\\n　に疲れるからって」"
    ]
  },
  {
    "op": "41",
    "offset": 2786,
    "value": [
