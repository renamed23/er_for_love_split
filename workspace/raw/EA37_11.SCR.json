    "offset": 8878,
    "value": [
      "u16:155",
      "u8:0",
      "u8:0",
      "エレナ",
      "「はい、北条です」"
    ]
  },
  {
    "op": "42",
    "offset": 8909,
    "value": [
      "u16:156",
      "u8:0",
      "u8:0",
      "花丸",
      "「あ、おれ」"
    ]
  },
  {
    "op": "23",
    "offset": 8932,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
