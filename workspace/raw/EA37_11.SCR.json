      "「エレナ！　エレナ！　ボウリング部の後輩から。──獅子\\n　堂さんって」"
    ]
  },
  {
    "op": "41",
    "offset": 8818,
    "value": [
      "u16:154",
      "u8:0",
      "　多分、どっちか聞いているのだろう。"
    ]
  },
  {
    "op": "23",
    "offset": 8859,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
