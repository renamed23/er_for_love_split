    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "青山",
      "「おまえはいいな。いくらお局様でも、彼女がいるんだもん\\n　な」"
    ]
  },
  {
    "op": "41",
    "offset": 809,
    "value": [
