    ]
  },
  {
    "op": "42",
    "offset": 953,
    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ほとんど。ゼミと言語学が１つ残ってるけど」"
    ]
  },
  {
    "op": "42",
    "offset": 1010,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "花丸",
