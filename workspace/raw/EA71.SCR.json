  {
    "op": "42",
    "offset": 792,
    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "エレナ",
      "「一年目なんだから、ちゃんと授業出といた方がいいわよ。\\n　落とすと後が大変よ」"
    ]
  },
  {
    "op": "42",
    "offset": 883,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "花丸",
