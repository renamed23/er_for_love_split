    "offset": 4056,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1292.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4075,
    "value": [
      "u16:41",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あっ……あぁぁん……凄い……お兄ちゃんのが……あぁぁっ\\n　……」"
    ]
  },
  {
    "op": "41",
    "offset": 4152,
    "value": [
      "u16:42",
      "u8:0",
      "　陶酔した表情でルナが言う。"
    ]
  },
  {
