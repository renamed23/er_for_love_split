      "u16:0",
      "u8:0",
      "　おれは部屋に戻った。"
    ]
  },
  {
    "op": "41",
    "offset": 105,
    "value": [
      "u16:1",
      "u8:0",
      "　見つかったら、という思いもあったけれど、何をしている\\nんだろうという意識もあった。"
    ]
  },
  {
    "op": "41",
    "offset": 194,
    "value": [
      "u16:2",
      "u8:0",
      "　おれには──"
    ]
  },
  {
    "op": "41",
    "offset": 213,
    "value": [
      "u16:3",
      "u8:0",
      "　おれにはルナがいるのに。"
    ]
  },
  {
    "op": "41",
    "offset": 244,
    "value": [
      "u16:4",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 255,
    "value": [
      "u16:5",
      "u8:0",
      "　欲望って、なぜ際限がないんだろう。"
    ]
  },
  {
    "op": "41",
    "offset": 296,
    "value": [
