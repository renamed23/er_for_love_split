    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "ルナ",
      "「いいよ、お兄ちゃんのだもん。それに、いっぱいイッてく\\n　れると、なんかうれしい」"
    ]
  },
  {
    "op": "41",
    "offset": 3016,
    "value": [
      "u16:33",
      "u8:0",
      "　少しはにかんでルナが言う。"
    ]
  },
