    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "ルナ",
      "「わっ……まだ出てくる……お兄ちゃん凄い……」"
    ]
  },
  {
    "op": "42",
    "offset": 2879,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "花丸",
      "「ごめん……」"
    ]
  },
  {
    "op": "23",
