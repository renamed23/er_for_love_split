    "value": [
      "u16:64",
      "u8:0",
      "u8:0",
      "ルナ",
      "「……」"
    ]
  },
  {
    "op": "23",
    "offset": 4363,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0428.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4382,
    "value": [
      "u16:65",
      "u8:0",
      "u8:0",
      "樹里",
      "「あんた文句言うけどさ、じゃあ、どれだけ花丸くんにして\\n　あげたわけ？　お茶淹れた？」"
    ]
  },
