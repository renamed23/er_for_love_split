    "value": [
      "u16:79",
      "u8:0",
      "u8:0",
      "ルナ",
      "「え？　そんな勝手なこと──」"
    ]
  },
  {
    "op": "23",
    "offset": 5511,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0435.ogg"
    ]
  },
