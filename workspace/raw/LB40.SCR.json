    "op": "42",
    "offset": 5340,
    "value": [
      "u16:78",
      "u8:0",
      "u8:0",
      "樹里",
      "「頭来てんでしょ？　頼りにならないって思ってんでしょ？\\n　じゃ、別れちゃいな。別れて藤原と付き合え」"
    ]
  },
