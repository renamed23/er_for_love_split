      "u16:67",
      "u8:0",
      "u8:0",
      "樹里",
      "「じゃあ、最近は」"
    ]
  },
  {
    "op": "41",
    "offset": 4573,
    "value": [
      "u16:68",
      "u8:0",
      "　また止まった。"
    ]
  },
  {
    "op": "41",
    "offset": 4594,
    "value": [
      "u16:69",
      "u8:0",
      "　淹れた記憶が──ない。"
    ]
  },
