    "op": "23",
    "offset": 4623,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0430.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4642,
    "value": [
      "u16:70",
      "u8:0",
      "u8:0",
      "樹里",
      "「ほら見ろ。ただのわがまま娘じゃないんだからさ、しっか\\n　りしろよ」"
    ]
  },
  {
    "op": "23",
    "offset": 4721,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_2098.ogg"
    ]
  },
  {
    "op": "42",
