    "offset": 2152,
    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ひょっとして、ストーカーですか」"
    ]
  },
  {
    "op": "42",
    "offset": 2197,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "英一郎",
      "「ま、まさか。無隣堂に用事があったんだ」"
    ]
  },
