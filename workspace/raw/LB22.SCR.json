      "u16:30",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あ……なんでこんなところにいるの？」"
    ]
  },
  {
    "op": "42",
    "offset": 2092,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "英一郎",
      "「あ、いや……ちょっと……」"
    ]
  },
