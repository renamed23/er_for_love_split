    "value": [
      "u16:42",
      "u8:0",
      "u8:0",
      "英一郎",
      "「うん。おもしろいよ。読む？」"
    ]
  },
  {
    "op": "23",
    "offset": 2625,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_2011.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2644,
    "value": [
      "u16:43",
      "u8:0",
      "u8:0",
      "ルナ",
      "「でも、藤原さんが読むんでしょ？」"
    ]
  },
  {
    "op": "42",
    "offset": 2689,
    "value": [
      "u16:44",
      "u8:0",
      "u8:0",
      "英一郎",
      "「全部読むの時間かかると思うから。あとで返してくれたら\\n　それでいいよ」"
    ]
  },
  {
    "op": "23",
    "offset": 2774,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_2012.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2793,
    "value": [
      "u16:45",
      "u8:0",
      "u8:0",
      "ルナ",
      "「でも、読んでる暇ないしな～」"
    ]
  },
  {
    "op": "42",
    "offset": 2834,
    "value": [
      "u16:46",
      "u8:0",
      "u8:0",
      "英一郎",
      "「速読の練習になるよ。２、３冊読めばもうどんな長文も来\\n　いって感じになるから」"
    ]
  },
  {
    "op": "23",
    "offset": 2927,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_2013.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2946,
    "value": [
      "u16:47",
      "u8:0",
      "u8:0",
      "ルナ",
      "「へ～え。どうしようかな」"
    ]
  },
  {
    "op": "42",
    "offset": 2983,
    "value": [
      "u16:48",
      "u8:0",
      "u8:0",
      "英一郎",
      "「お願い、借りてちょうだい」"
    ]
  },
  {
    "op": "41",
    "offset": 3024,
    "value": [
      "u16:49",
      "u8:0",
      "　思わず笑ってしまった。"
    ]
  },
  {
    "op": "23",
    "offset": 3053,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_2014.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 3072,
    "value": [
      "u16:50",
      "u8:0",
      "u8:0",
      "ルナ",
      "「借りてくれって言う人、初めて聞いたよ」"
    ]
  },
  {
    "op": "42",
    "offset": 3123,
    "value": [
      "u16:51",
      "u8:0",
