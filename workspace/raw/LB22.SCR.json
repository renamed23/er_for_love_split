    "value": [
      "u16:34",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ふ～ん」"
    ]
  },
  {
    "op": "42",
    "offset": 2290,
    "value": [
      "u16:35",
      "u8:0",
      "u8:0",
      "英一郎",
      "「信じてないだろ」"
    ]
  },
  {
    "op": "23",
    "offset": 2321,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
