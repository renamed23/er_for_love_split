    ]
  },
  {
    "op": "42",
    "offset": 2340,
    "value": [
      "u16:36",
      "u8:0",
      "u8:0",
      "ルナ",
      "「当然」"
    ]
  },
  {
    "op": "42",
    "offset": 2359,
    "value": [
      "u16:37",
      "u8:0",
      "u8:0",
      "英一郎",
      "「ほんとなんだから」"
    ]
  },
  {
    "op": "41",
    "offset": 2392,
    "value": [
      "u16:38",
      "u8:0",
      "　英一郎さんは、包みのなかを見せてくれた。"
    ]
  },
  {
    "op": "41",
    "offset": 2439,
    "value": [
      "u16:39",
      "u8:0",
      "　わっ。"
    ]
  },
  {
    "op": "41",
    "offset": 2452,
    "value": [
      "u16:40",
      "u8:0",
      "　全部、原書。凄い。"
    ]
  },
  {
    "op": "23",
    "offset": 2477,
    "value": [
      "u8:0",
      "u16:65535",
