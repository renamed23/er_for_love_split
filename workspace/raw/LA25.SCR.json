  {
    "op": "41",
    "offset": 110,
    "value": [
      "u16:1",
      "u8:0",
      "　ルナの講習が始まって１週間ほどたった頃だった。"
    ]
  },
  {
    "op": "42",
    "offset": 163,
    "value": [
      "u16:2",
      "u8:0",
      "u8:0",
      "親父",
      "「家に呼ぶのがいいかなって考えてるんだけど」"
    ]
  },
  {
    "op": "42",
    "offset": 218,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "花丸",
      "「家？　家に呼ぶの？」"
    ]
  },
  {
    "op": "42",
    "offset": 251,
    "value": [
      "u16:4",
      "u8:0",
      "u8:0",
      "親父",
      "「おまえたち、二人ともびっくりするぞ」"
    ]
  },
  {
    "op": "42",
    "offset": 300,
    "value": [
      "u16:5",
      "u8:0",
      "u8:0",
      "花丸",
      "「美人なのか？」"
    ]
  },
  {
    "op": "41",
    "offset": 327,
    "value": [
      "u16:6",
      "u8:0",
      "　親父はにやにやと笑う。"
    ]
  },
  {
    "op": "41",
    "offset": 356,
    "value": [
      "u16:7",
      "u8:0",
      "　何か企んでる？"
    ]
  },
  {
    "op": "42",
    "offset": 377,
    "value": [
      "u16:8",
      "u8:0",
      "u8:0",
      "親父",
      "「二人ともいいって言うのならすぐ連絡しようと思ってるん\\n　だけど」"
    ]
  },
  {
    "op": "42",
    "offset": 454,
    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれの方は、いいけど……」"
    ]
  },
  {
    "op": "41",
    "offset": 493,
    "value": [
      "u16:10",
      "u8:0",
      "　おれは風丸の方を見た。"
    ]
  },
  {
    "op": "49",
    "offset": 522,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 526,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 530,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
