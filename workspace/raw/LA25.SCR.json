    ]
  },
  {
    "op": "41",
    "offset": 1951,
    "value": [
      "u16:28",
      "u8:0",
      "　親父は言って洗面所の方へ引き上げていった。"
    ]
  },
  {
    "op": "49",
    "offset": 2000,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
