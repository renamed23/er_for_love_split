    "value": [
      "bytes:19 F4 01 00"
    ]
  },
  {
    "op": "42",
    "offset": 569,
    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "風丸",
      "「父さんの好きにすればいいと思う。別に反対もしないから」"
    ]
  },
  {
    "op": "49",
    "offset": 636,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 640,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 644,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B003"
    ]
  },
  {
    "op": "4A",
    "offset": 659,
    "value": [
      "bytes:19 F4 01 00"
    ]
  },
  {
    "op": "41",
    "offset": 664,
    "value": [
      "u16:12",
      "u8:0",
      "　風丸は、リビングを出て階段を上がっていった。"
    ]
  },
  {
    "op": "21",
    "offset": 715,
    "value": [
      "u8:1",
      "u16:1000",
      "BGM10"
    ]
  },
  {
    "op": "49",
    "offset": 725,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 729,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 733,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B003"
    ]
  },
  {
    "op": "48",
    "offset": 748,
    "value": [
      "u8:1",
      "u16:224",
      "u16:0",
      "u32:0",
