    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 2008,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B002"
    ]
  },
  {
    "op": "4A",
    "offset": 2023,
    "value": [
      "bytes:0D E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 2028,
    "value": [
      "u16:29",
      "u8:0",
      "　おれは洗い物を始めた。"
    ]
  },
  {
    "op": "41",
    "offset": 2057,
    "value": [
      "u16:30",
      "u8:0",
      "　新しいお母さん。"
    ]
  },
  {
    "op": "41",
    "offset": 2080,
    "value": [
      "u16:31",
      "u8:0",
      "　まだ再婚するって決まったわけじゃないからお母さんじゃ\\nないけれど、なんだか変だ。"
    ]
  },
  {
    "op": "41",
    "offset": 2167,
    "value": [
      "u16:32",
      "u8:0",
      "　感覚がつかめない。"
    ]
  },
  {
    "op": "41",
    "offset": 2192,
    "value": [
      "u16:33",
      "u8:0",
      "　いまさら母親って気もするし……"
    ]
  },
  {
    "op": "49",
    "offset": 2229,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
