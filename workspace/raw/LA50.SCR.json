      "u16:69",
      "u8:0",
      "　合格発表が始まった。といっても、他の大学。"
    ]
  },
  {
    "op": "41",
    "offset": 2859,
    "value": [
      "u16:70",
      "u8:0",
      "　地元のテレビ局が、武蔵原工業大学での胴上げを映してい\\nた。ふいに切なくなった。"
    ]
  },
  {
    "op": "41",
    "offset": 2944,
    "value": [
      "u16:71",
      "u8:0",
      "　去年も、同じように見てたんだなあ、と思い出す。"
    ]
  },
  {
    "op": "41",
    "offset": 2997,
    "value": [
      "u16:72",
      "u8:0",
      "　自分が落ちるとも知らずに。"
    ]
  },
  {
    "op": "41",
    "offset": 3030,
    "value": [
      "u16:73",
      "u8:0",
      "　早くわたしもあんなふうになりたい。"
    ]
  },
