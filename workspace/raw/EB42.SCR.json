    ]
  },
  {
    "op": "41",
    "offset": 556,
    "value": [
      "u16:12",
      "u8:0",
      "　あれこれ悩みそうで電気を消してベッドに入った。"
    ]
  },
  {
    "op": "41",
    "offset": 609,
    "value": [
      "u16:13",
      "u8:0",
      "　でも、眠れなかった。"
    ]
  },
  {
    "op": "41",
    "offset": 636,
    "value": [
      "u16:14",
      "u8:0",
      "　１時になっても、２時になっても。"
    ]
  },
  {
    "op": "41",
    "offset": 675,
    "value": [
      "u16:15",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 686,
    "value": [
      "u16:16",
      "u8:0",
      "　花丸──起きてるかな……。"
