      "u16:8",
      "u8:0",
      "u8:0",
      "エレナ",
      "「レーンがよかったのかしら」"
    ]
  },
  {
    "op": "41",
    "offset": 637,
    "value": [
      "u16:9",
      "u8:0",
      "　エレナさんが意外と涼しい顔で言う。"
    ]
  },
