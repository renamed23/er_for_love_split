    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "エレナ",
      "「そのうち花丸も出来るようになるわよ」"
    ]
  },
  {
    "op": "42",
    "offset": 913,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "花丸",
