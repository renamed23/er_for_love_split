  },
  {
    "op": "42",
    "offset": 4259,
    "value": [
      "u16:69",
      "u8:0",
      "u8:0",
      "エレナ",
      "「女の子が二人ともいなくなっちゃうのがちょっと厳しいけ\\n　ど」"
    ]
  },
  {
    "op": "42",
    "offset": 4334,
    "value": [
      "u16:70",
      "u8:0",
      "u8:0",
      "花丸",
      "「入ってくるよ」"
    ]
  },
  {
    "op": "23",
    "offset": 4361,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1383.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4380,
    "value": [
      "u16:71",
      "u8:0",
      "u8:0",
      "エレナ",
      "「かわいい子に目移りしたら会社から駆けつけてボール投げ\\n　つけちゃうから」"
    ]
  },
  {
    "op": "41",
    "offset": 4467,
    "value": [
      "u16:72",
      "u8:0",
      "　思わず苦笑する。"
    ]
  },
  {
    "op": "23",
    "offset": 4490,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1384.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4509,
    "value": [
      "u16:73",
      "u8:0",
      "u8:0",
      "エレナ",
      "「風丸、ママと仲良くなったわね」"
    ]
  },
  {
    "op": "42",
    "offset": 4554,
    "value": [
      "u16:74",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん。一番あいつが渋ってたのに」"
    ]
  },
  {
    "op": "23",
    "offset": 4599,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1385.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4618,
    "value": [
      "u16:75",
      "u8:0",
      "u8:0",
      "エレナ",
      "「そういうものよ」"
    ]
  },
  {
    "op": "41",
    "offset": 4649,
    "value": [
      "u16:76",
      "u8:0",
      "　そうかもしれない。"
    ]
  },
  {
    "op": "23",
    "offset": 4674,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1386.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4693,
    "value": [
      "u16:77",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あと１年、大学にいられたらな……」"
    ]
  },
  {
    "op": "41",
    "offset": 4742,
    "value": [
      "u16:78",
      "u8:0",
      "　エレナさんがぽつりとつぶやいた。"
    ]
  },
  {
    "op": "42",
    "offset": 4781,
    "value": [
      "u16:79",
      "u8:0",
      "u8:0",
      "花丸",
      "「会社に行ったって、おれはいっしょだよ。家だって同じだ\\n　し。山手に通うんだろ？」"
    ]
  },
  {
    "op": "23",
    "offset": 4874,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
