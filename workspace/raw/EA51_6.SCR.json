    "value": [
      "u16:27",
      "u8:0",
      "u8:0",
      "風丸",
      "「ありささん、今日早いの？」"
    ]
  },
  {
    "op": "41",
    "offset": 2000,
    "value": [
      "u16:28",
      "u8:0",
      "　風丸が訊く。"
    ]
  },
