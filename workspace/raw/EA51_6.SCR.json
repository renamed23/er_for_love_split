    "value": [
      "u16:61",
      "u8:0",
      "　エレナさんの部屋でエッチして、コートを羽織ってベラン\\nダに出る。"
    ]
  },
  {
    "op": "41",
    "offset": 4000,
    "value": [
      "u16:62",
      "u8:0",
      "　夜空に浮かぶオリオン座。"
    ]
