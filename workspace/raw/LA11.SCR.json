  {
    "op": "41",
    "offset": 462,
    "value": [
      "u16:7",
      "u8:0",
      "　親父がダイニングテーブルに座る。"
    ]
  },
  {
    "op": "42",
    "offset": 501,
    "value": [
      "u16:8",
      "u8:0",
      "u8:0",
      "親父",
      "「──母さん、欲しくないか？」"
    ]
  },
  {
    "op": "42",
    "offset": 542,
    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "花丸",
      "「何だよ、いきなり」"
    ]
  },
  {
    "op": "42",
    "offset": 573,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "親父",
      "「いや、うん……」"
    ]
  },
  {
    "op": "41",
    "offset": 602,
    "value": [
      "u16:11",
      "u8:0",
      "　親父は口を濁した。新聞紙をめくる。"
    ]
  },
  {
    "op": "42",
    "offset": 643,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "親父",
      "「ルナちゃんと付き合ってるんだってな」"
    ]
  },
  {
    "op": "42",
    "offset": 692,
    "value": [
      "u16:13",
      "u8:0",
      "u8:0",
      "花丸",
