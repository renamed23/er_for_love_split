    ]
  },
  {
    "op": "42",
    "offset": 775,
    "value": [
      "u16:16",
      "u8:0",
      "u8:0",
      "親父",
      "「今日、行くのか」"
    ]
  },
  {
    "op": "42",
    "offset": 804,
    "value": [
      "u16:17",
      "u8:0",
      "u8:0",
      "花丸",
      "「え？　うん……」"
    ]
  },
  {
    "op": "42",
    "offset": 833,
    "value": [
      "u16:18",
      "u8:0",
      "u8:0",
      "親父",
      "「そうか。じゃあ、父さんはおいしいものでも食べてくるか\\n　な」"
    ]
  },
  {
    "op": "41",
    "offset": 906,
    "value": [
      "u16:19",
      "u8:0",
      "　その気があるような、ないような声で言って新聞紙をめく\\nる。"
    ]
  },
