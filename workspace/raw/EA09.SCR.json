      "u16:0"
    ]
  },
  {
    "op": "25",
    "offset": 1576,
    "value": [
      "u8:0",
      "u16:256",
      "SE_KOKI.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1592,
    "value": [
      "u16:21",
      "u8:0",
      "u8:0",
      "花丸",
      "「はい、獅子堂です」"
    ]
  },
  {
    "op": "23",
    "offset": 1623,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0001.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1642,
    "value": [
      "u16:22",
      "u8:0",
      "u8:0",
      "ルナ",
      "「お兄ちゃん？」"
    ]
  },
  {
    "op": "21",
    "offset": 1669,
    "value": [
      "u8:0",
      "u16:0",
      "BGM04"
    ]
  },
  {
    "op": "41",
    "offset": 1679,
    "value": [
      "u16:23",
      "u8:0",
      "　鮎川ルナだった。"
    ]
  },
  {
    "op": "41",
    "offset": 1702,
    "value": [
      "u16:24",
      "u8:0",
      "　おれの親父には５つ歳の離れた妹がいる。その妹が鮎川家\\nに嫁いで出来た娘が、ルナだ。つまり、おれにとってルナは\\n従妹にあたるというわけだ。"
    ]
  },
  {
    "op": "41",
    "offset": 1845,
    "value": [
      "u16:25",
      "u8:0",
      "　ルナは、親元の久遠（くおん）町を出て、今春から山手市\\nでマンション暮らしを始めていた。引っ越し手伝おうかと言っ\\nてみたのだが、叔母と叔父──つまり、ルナの両親に丁重に\\n断られてしまった。"
    ]
  },
  {
    "op": "41",
    "offset": 2038,
    "value": [
      "u16:26",
      "u8:0",
      "　ルナは、本当はおれと同じ蘭山大学の文学部に行くはずだっ\\nた。"
    ]
  },
  {
    "op": "41",
    "offset": 2105,
    "value": [
      "u16:27",
      "u8:0",
      "　が──蘭山大学は落ちて、私立の四天王大学に合格。"
    ]
  },
  {
    "op": "41",
    "offset": 2160,
    "value": [
      "u16:28",
      "u8:0",
      "　本人は浪人して蘭山大学を再受験すると言い張ったが、親\\nとの闘争に敗れて、結局、四天王大学の仏文科に入学したの\\nだった。"
    ]
  },
  {
    "op": "23",
    "offset": 2285,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0002.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2304,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "ルナ",
      "「もうちょっと早く電話しようと思ってたんだけど、色々あっ\\n　て……えへへ」"
    ]
  },
  {
    "op": "42",
    "offset": 2389,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "花丸",
      "「元気か？」"
    ]
  },
  {
    "op": "23",
    "offset": 2412,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0003.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2431,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "ルナ",
      "「元気してるよ？」"
    ]
  },
  {
    "op": "42",
    "offset": 2460,
    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "花丸",
      "「独り暮らしはどうだ」"
    ]
  },
  {
    "op": "23",
    "offset": 2493,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0004.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2512,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "ルナ",
      "「お兄ちゃんがいないから寂しい、なんて、えへへ」"
    ]
  },
  {
    "op": "41",
    "offset": 2571,
    "value": [
      "u16:34",
      "u8:0",
      "　いきなりストレートな冗談に、ドキッとする。"
    ]
  },
  {
    "op": "23",
    "offset": 2620,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0005.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2639,
    "value": [
      "u16:35",
      "u8:0",
      "u8:0",
      "ルナ",
      "「今度の休み、お兄ちゃんのところに遊びに行っていい？」"
    ]
  },
  {
    "op": "42",
    "offset": 2704,
    "value": [
      "u16:36",
      "u8:0",
      "u8:0",
      "花丸",
      "「返り討ちにしてくれる」"
    ]
  },
  {
    "op": "23",
    "offset": 2739,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0006.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2758,
    "value": [
      "u16:37",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あはは」"
    ]
  },
  {
    "op": "41",
    "offset": 2779,
    "value": [
      "u16:38",
      "u8:0",
      "　電話の向こうでルナが笑う。"
    ]
  },
  {
    "op": "23",
    "offset": 2812,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0007.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2831,
    "value": [
      "u16:39",
      "u8:0",
      "u8:0",
      "ルナ",
      "「何かお土産持ってこうか」"
    ]
  },
  {
    "op": "42",
    "offset": 2868,
    "value": [
      "u16:40",
      "u8:0",
      "u8:0",
      "花丸",
      "「別にいいぞ。親父も──」"
    ]
  },
  {
    "op": "23",
    "offset": 2905,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0008.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2924,
    "value": [
      "u16:41",
      "u8:0",
      "u8:0",
      "ルナ",
      "「家のじゃなくて、お兄ちゃんの」"
    ]
  },
  {
    "op": "42",
    "offset": 2967,
    "value": [
      "u16:42",
      "u8:0",
      "u8:0",
      "花丸",
      "「では、山吹き色の菓子」"
    ]
  },
  {
    "op": "23",
    "offset": 3002,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0009.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 3021,
    "value": [
      "u16:43",
      "u8:0",
      "u8:0",
      "ルナ",
      "「あはは……小判なんかうちないよ」"
    ]
  },
  {
    "op": "41",
    "offset": 3066,
    "value": [
      "u16:44",
      "u8:0",
      "　ルナが笑う。"
    ]
  },
  {
    "op": "23",
    "offset": 3085,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0010.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 3104,
    "value": [
      "u16:45",
      "u8:0",
      "u8:0",
      "ルナ",
      "「とにかく、何か持ってくね」"
    ]
  },
  {
    "op": "42",
    "offset": 3143,
    "value": [
      "u16:46",
      "u8:0",
      "u8:0",
      "花丸",
      "「おう」"
    ]
  },
