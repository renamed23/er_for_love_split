    "op": "42",
    "offset": 4839,
    "value": [
      "u16:73",
      "u8:0",
      "u8:0",
      "樹里",
      "「花丸くん、北条にいじめられてない？」"
    ]
  },
  {
    "op": "42",
    "offset": 4888,
    "value": [
      "u16:74",
      "u8:0",
      "u8:0",
      "花丸",
      "「おれ、いじめられっ子に見えます？」"
    ]
  },
  {
    "op": "23",
    "offset": 4935,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0042.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 4954,
    "value": [
      "u16:75",
      "u8:0",
      "u8:0",
      "樹里",
      "「……見えないけど」"
    ]
  },
  {
    "op": "42",
    "offset": 4985,
    "value": [
      "u16:76",
      "u8:0",
      "u8:0",
      "花丸",
      "「何、心配してんですか。樹里さん、心配性？」"
    ]
  },
  {
    "op": "23",
    "offset": 5040,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0043.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 5059,
    "value": [
      "u16:77",
      "u8:0",
      "u8:0",
      "樹里",
      "「違うわよ。ただ、北条とデートしてて、大丈夫かなと思っ\\n　て」"
    ]
  },
  {
    "op": "23",
    "offset": 5132,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0044.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 5151,
    "value": [
      "u16:78",
      "u8:0",
      "u8:0",
      "樹里",
      "「──本気で付き合う気なの？」"
    ]
  },
  {
    "op": "42",
    "offset": 5192,
    "value": [
      "u16:79",
      "u8:0",
      "u8:0",
      "花丸",
      "「付き合うも何も、まだ付き合ってないじゃないですか」"
    ]
  },
  {
    "op": "23",
    "offset": 5255,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "jur_0045.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 5274,
    "value": [
      "u16:80",
      "u8:0",
      "u8:0",
      "樹里",
      "「やめるなら、今のうちだよ」"
    ]
  },
  {
    "op": "42",
    "offset": 5313,
    "value": [
      "u16:81",
      "u8:0",
      "u8:0",
      "花丸",
      "「へ？」"
    ]
  },
  {
