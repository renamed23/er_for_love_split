  },
  {
    "op": "42",
    "offset": 323,
    "value": [
      "u16:7",
      "u8:0",
      "u8:0",
      "ルナ",
      "「数学がほぼ全滅。英語もだめだめ。一番よくて国語で偏差\\n　値５５。へへへ……」"
    ]
  },
  {
    "op": "41",
    "offset": 412,
    "value": [
      "u16:8",
      "u8:0",
      "　笑いに力がない。"
    ]
  },
  {
    "op": "42",
    "offset": 435,
    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "花丸",
      "「何かうまいもの食うか？」"
    ]
  },
  {
