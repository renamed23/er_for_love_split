      "u16:18",
      "u8:0",
      "u8:0",
      "ルナ",
      "「……」"
    ]
  },
  {
    "op": "42",
    "offset": 1031,
    "value": [
      "u16:19",
      "u8:0",
      "u8:0",
      "花丸",
      "「親父のことか？」"
    ]
  },
  {
    "op": "23",
    "offset": 1060,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
