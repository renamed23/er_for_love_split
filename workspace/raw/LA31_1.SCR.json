      "u16:2",
      "u8:0",
      "u8:0",
      "ルナ",
      "「やっぱだめだった」"
    ]
  },
  {
    "op": "42",
    "offset": 218,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "花丸",
      "「Ｄ？」"
    ]
  },
  {
    "op": "41",
    "offset": 237,
    "value": [
      "u16:4",
      "u8:0",
      "　ルナが苦笑いする。"
    ]
  },
  {
    "op": "41",
    "offset": 262,
    "value": [
      "u16:5",
      "u8:0",
      "　成績表を見た。"
    ]
  },
  {
    "op": "41",
    "offset": 283,
    "value": [
      "u16:6",
      "u8:0",
      "　Ｅ判定だった。"
    ]
  },
  {
    "op": "23",
    "offset": 304,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
