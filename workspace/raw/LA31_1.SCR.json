    ]
  },
  {
    "op": "42",
    "offset": 1079,
    "value": [
      "u16:20",
      "u8:0",
      "u8:0",
      "ルナ",
      "「……」"
    ]
  },
  {
    "op": "42",
    "offset": 1098,
    "value": [
      "u16:21",
      "u8:0",
      "u8:0",
      "花丸",
      "「親父の結婚、反対だったのか？」"
    ]
  },
  {
    "op": "41",
    "offset": 1141,
    "value": [
      "u16:22",
      "u8:0",
      "　ルナは答えなかった。"
    ]
  },
  {
    "op": "42",
    "offset": 1168,
    "value": [
      "u16:23",
      "u8:0",
      "u8:0",
      "花丸",
      "「でも、親父もあの歳だし、老後もあるし──」"
    ]
  },
  {
    "op": "41",
    "offset": 1223,
    "value": [
      "u16:24",
      "u8:0",
      "　ルナは答えない。"
    ]
  },
  {
    "op": "42",
    "offset": 1246,
    "value": [
      "u16:25",
      "u8:0",
      "u8:0",
      "花丸",
      "「今度家に遊びに来いよ。きっと気に入ると思うよ。エレナ\\n　さんはちょっと毒舌だけど──」"
    ]
  },
  {
    "op": "41",
    "offset": 1345,
    "value": [
      "u16:26",
      "u8:0",
      "　ルナはやはり答えない。"
    ]
  },
  {
    "op": "42",
    "offset": 1374,
    "value": [
      "u16:27",
      "u8:0",
      "u8:0",
      "花丸",
      "「ルナ？」"
    ]
  },
  {
    "op": "23",
    "offset": 1395,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1396.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1414,
    "value": [
      "u16:28",
      "u8:0",
      "u8:0",
      "ルナ",
      "「……わたし、いまさら従姉なんかいらない」"
    ]
  },
  {
    "op": "42",
    "offset": 1467,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "花丸",
      "「え？」"
    ]
  },
  {
    "op": "23",
    "offset": 1486,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1397.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1505,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "ルナ",
      "「わたしが先にお兄ちゃんの妹になりたかったのに……ずる\\n　いよ……」"
    ]
  },
  {
    "op": "42",
    "offset": 1584,
    "value": [
      "u16:31",
      "u8:0",
      "u8:0",
      "花丸",
      "「ルナ……」"
    ]
  },
  {
    "op": "23",
    "offset": 1607,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1398.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1626,
    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "ルナ",
      "「昨日までお兄ちゃんとは全然他人だったくせに……ずるい\\n　よ……」"
    ]
  },
  {
    "op": "42",
    "offset": 1703,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "花丸",
      "「けど、本当に兄妹だったらこうやっておおっぴらに付き合\\n　うことだってできないし、結婚だってできないぞ」"
    ]
  },
  {
    "op": "23",
    "offset": 1818,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1399.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1837,
    "value": [
      "u16:34",
      "u8:0",
      "u8:0",
      "ルナ",
      "「それでも、お兄ちゃんといっしょに住みたかったもん……\\n　お兄ちゃんの妹になりたかったんだもん……それだったら\\n　休みになるたびに別れなくてもすむもん……」"
    ]
  },
  {
    "op": "41",
    "offset": 2004,
    "value": [
      "u16:35",
      "u8:0",
      "　おれは返す言葉がなかった。"
    ]
