    "op": "42",
    "offset": 356,
    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "樹里",
      "「死んでも姉さんなんて言わない」"
    ]
  },
  {
    "op": "49",
    "offset": 399,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
