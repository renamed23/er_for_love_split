    "value": [
      "u16:0",
      "u8:0",
      "u8:0",
      "樹里",
      "「そっか。じゃ、同じ家族になるのか」"
    ]
  },
  {
    "op": "41",
    "offset": 147,
    "value": [
      "u16:1",
      "u8:0",
      "　なぜだか樹里はうれしそうだった。"
    ]
  },
  {
    "op": "23",
    "offset": 186,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_1210.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 205,
    "value": [
      "u16:2",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あなたが風丸くんと結婚したら、わたしが義理のお姉様に\\n　なるわけよ」"
    ]
  },
  {
    "op": "49",
    "offset": 288,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
