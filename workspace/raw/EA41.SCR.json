    ]
  },
  {
    "op": "42",
    "offset": 3714,
    "value": [
      "u16:45",
      "u8:0",
      "u8:0",
      "宗彦",
      "「きみの天国のママもきっと言ってるよ。無理をしないでね、\\n　花丸ちゃん。上手になるのはお料理だけでいいのよ」"
    ]
  },
