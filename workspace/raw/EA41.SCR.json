      "u16:39",
      "u8:0",
      "u8:0",
      "宗彦",
      "「これはこれはボウリングの本ですか。ひょっとしてお勉強\\n　かな」"
    ]
  },
  {
    "op": "42",
    "offset": 3303,
    "value": [
      "u16:40",
      "u8:0",
      "u8:0",
      "花丸",
