  {
    "op": "41",
    "offset": 60,
    "value": [
      "u16:0",
      "u8:0",
      "　今日はお兄ちゃんにいっぱい元気を分けてもらった。"
    ]
  },
  {
    "op": "41",
    "offset": 115,
    "value": [
      "u16:1",
      "u8:0",
      "　──はずなのに、"
    ]
  },
  {
    "op": "26",
    "offset": 138,
    "value": [
      "u16:0"
    ]
  },
  {
    "op": "25",
    "offset": 141,
    "value": [
      "u8:0",
      "u16:0",
      "SE_CL_MD.ogg"
    ]
  },
  {
    "op": "49",
    "offset": 158,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 162,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 166,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B020DARK"
    ]
  },
  {
    "op": "4A",
    "offset": 185,
    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 190,
    "value": [
      "u16:2",
      "u8:0",
      "　家に帰ってくると、寂しさで部屋のなかがいっぱいになっ\\nていた。"
    ]
  },
  {
    "op": "41",
    "offset": 259,
    "value": [
      "u16:3",
      "u8:0",
      "　飲みかけの紅茶。"
    ]
  },
  {
    "op": "41",
    "offset": 282,
    "value": [
      "u16:4",
      "u8:0",
      "　食べ残しのお皿。"
    ]
  },
  {
    "op": "41",
    "offset": 305,
    "value": [
      "u16:5",
      "u8:0",
      "　そして、"
    ]
  },
  {
    "op": "49",
    "offset": 320,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 324,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 328,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B021DARK"
    ]
  },
  {
    "op": "4A",
    "offset": 347,
    "value": [
      "bytes:0D F4 01 00"
    ]
  },
  {
    "op": "41",
    "offset": 352,
    "value": [
      "u16:6",
      "u8:0",
      "　今朝のままのベッド。"
    ]
  },
  {
    "op": "41",
    "offset": 379,
    "value": [
      "u16:7",
      "u8:0",
      "　目に映るすべてが、お兄ちゃんがいないことを物語ってい\\nた。"
    ]
  },
  {
    "op": "41",
    "offset": 444,
    "value": [
      "u16:8",
      "u8:0",
      "　なんだか、２日前のことが嘘みたいだった。初めてお兄ちゃ\\nんがお部屋に来る時は、ドキドキして、これから始まること\\nが凄く楽しみでワクワクしていたのに。"
    ]
  },
  {
    "op": "41",
    "offset": 599,
    "value": [
      "u16:9",
      "u8:0",
      "　映画だって、いっしょに見たのに。"
    ]
  },
  {
    "op": "41",
    "offset": 638,
    "value": [
      "u16:10",
      "u8:0",
      "　みんな──終わっちゃった。"
    ]
  },
  {
    "op": "41",
    "offset": 671,
    "value": [
      "u16:11",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 682,
    "value": [
      "u16:12",
      "u8:0",
      "　わたしは、そっとベッドに横たわってみた。"
    ]
  },
  {
    "op": "41",
    "offset": 729,
    "value": [
      "u16:13",
      "u8:0",
      "　──あ。"
    ]
  },
  {
    "op": "41",
    "offset": 744,
    "value": [
      "u16:14",
      "u8:0",
      "　お兄ちゃんの匂い。"
    ]
  },
  {
    "op": "41",
    "offset": 769,
    "value": [
      "u16:15",
      "u8:0",
      "　今朝までお兄ちゃんが寝ていた匂い。"
    ]
  },
  {
    "op": "41",
    "offset": 810,
    "value": [
      "u16:16",
      "u8:0",
      "　さっきまで、ずっとお兄ちゃんといっしょだったのに──"
    ]
  },
  {
    "op": "41",
    "offset": 869,
    "value": [
      "u16:17",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 880,
    "value": [
      "u16:18",
      "u8:0",
      "　わたしは、お兄ちゃんと同じ学校に行ったことがない。"
    ]
  },
  {
    "op": "41",
    "offset": 937,
    "value": [
      "u16:19",
      "u8:0",
      "　予備校は１年違い。"
    ]
  },
  {
    "op": "41",
    "offset": 962,
    "value": [
      "u16:20",
      "u8:0",
      "　今年受かっていたら同じ大学だったけれど──不合格。"
    ]
  },
  {
    "op": "41",
    "offset": 1019,
    "value": [
      "u16:21",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 1030,
    "value": [
      "u16:22",
      "u8:0",
      "　来年、いっしょの大学に行けるのかな。"
    ]
  },
  {
    "op": "41",
    "offset": 1073,
    "value": [
      "u16:23",
      "u8:0",
      "　ジンクスなのかな……。"
    ]
  },
  {
    "op": "49",
    "offset": 1102,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 1106,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
