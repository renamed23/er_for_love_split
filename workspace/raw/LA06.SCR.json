    "value": [
      "bytes:19 D0 07 00"
    ]
  },
  {
    "op": "49",
    "offset": 2168,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 2172,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 2176,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B199"
    ]
  },
  {
    "op": "4A",
