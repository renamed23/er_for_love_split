  {
    "op": "41",
    "offset": 60,
    "value": [
      "u16:0",
      "u8:0",
      "　７月──"
    ]
  },
  {
    "op": "41",
    "offset": 75,
    "value": [
      "u16:1",
      "u8:0",
      "　花丸くんがお泊まりに来たある日──"
    ]
  },
  {
    "op": "41",
    "offset": 116,
    "value": [
      "u16:2",
      "u8:0",
      "　突然、目が覚めた。"
    ]
  },
  {
    "op": "41",
    "offset": 141,
    "value": [
      "u16:3",
      "u8:0",
      "　もう、夜中の２時を回っていた。"
    ]
  },
  {
    "op": "41",
    "offset": 178,
    "value": [
      "u16:4",
      "u8:0",
      "　時計の音が、部屋で時を刻みつづけている。"
    ]
  },
  {
    "op": "41",
    "offset": 225,
    "value": [
      "u16:5",
      "u8:0",
      "　隣のベッドからは、静かな花丸くんの寝息。"
    ]
  },
  {
    "op": "41",
    "offset": 272,
    "value": [
      "u16:6",
      "u8:0",
      "　ビデオを借りて来て、二人で見て、"
    ]
  },
  {
    "op": "41",
    "offset": 311,
    "value": [
      "u16:7",
      "u8:0",
      "　布団に入って、エッチをして……"
    ]
  },
  {
    "op": "41",
    "offset": 348,
    "value": [
      "u16:8",
      "u8:0",
      "　これで花丸くんと寝るのは五度め。ママがいないたびに花\\n丸くんを誘って、部屋でエッチして、花丸くんと寝る。"
    ]
  },
  {
    "op": "41",
    "offset": 459,
    "value": [
      "u16:9",
      "u8:0",
      "　花丸くんと付き合い出してから、ずっと花丸くんばかりの\\n生活。"
    ]
  },
  {
    "op": "41",
    "offset": 526,
    "value": [
      "u16:10",
      "u8:0",
      "　サークルも花丸くん。"
    ]
  },
  {
    "op": "41",
    "offset": 553,
    "value": [
      "u16:11",
      "u8:0",
      "　帰りも花丸くん。"
    ]
  },
  {
    "op": "41",
    "offset": 576,
    "value": [
      "u16:12",
      "u8:0",
      "　電話も花丸くん。"
    ]
  },
  {
    "op": "41",
    "offset": 599,
    "value": [
      "u16:13",
      "u8:0",
      "　わたしは、花丸くんの寝顔を見た。"
    ]
  },
  {
    "op": "41",
    "offset": 638,
    "value": [
      "u16:14",
      "u8:0",
      "　風丸くんより、かわいくて優しい顔。"
    ]
  },
  {
    "op": "41",
    "offset": 679,
    "value": [
      "u16:15",
      "u8:0",
      "　わたしは、ちゅっとキスして、花丸くんに胸を押しつけた。"
    ]
  },
