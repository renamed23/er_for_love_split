    "value": [
      "u16:26",
      "u8:0",
      "u8:0",
      "鮎川",
      "「何、その言い方？」"
    ]
  },
  {
    "op": "23",
    "offset": 2030,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_0636.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 2049,
    "value": [
      "u16:27",
      "u8:0",
      "u8:0",
      "ルナ",
      "「うるさいなあ、こっちは勉強してんだから邪魔しないでよ」"
    ]
  },
  {
    "op": "23",
    "offset": 2116,
    "value": [
      "u8:0",
