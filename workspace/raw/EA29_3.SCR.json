    "value": [
      "u16:3",
      "u8:0",
      "u8:0",
      "エレナ",
      "「テーブルで食べちゃお」"
    ]
  },
  {
    "op": "42",
    "offset": 340,
    "value": [
      "u16:4",
      "u8:0",
      "u8:0",
      "花丸",
      "「テーブル？」"
    ]
  },
