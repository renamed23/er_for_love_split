  {
    "op": "41",
    "offset": 76,
    "value": [
      "u16:0",
      "u8:0",
      "　マンションに着くと、ママは帰っていなかった。"
    ]
  },
  {
    "op": "41",
    "offset": 127,
    "value": [
      "u16:1",
      "u8:0",
      "　休日なのに仕事。"
    ]
  },
  {
    "op": "41",
    "offset": 150,
    "value": [
      "u16:2",
      "u8:0",
      "　でも、仕方ない。中古で手に入れたマンションの支払いは\\n済んだけれど、生きるためには食べていかなきゃいけないの\\nだから。"
    ]
  },
  {
    "op": "41",
    "offset": 275,
    "value": [
      "u16:3",
      "u8:0",
      "　──なぜ、彼の待つ場所へ出かけてしまったのだろう。"
    ]
  },
  {
    "op": "41",
    "offset": 332,
    "value": [
      "u16:4",
      "u8:0",
      "　気が向いたから──というわけじゃないと思う。"
    ]
  },
  {
    "op": "41",
    "offset": 383,
    "value": [
      "u16:5",
      "u8:0",
      "　出かける前は、多分、いないだろうと思っていたのだから。"
    ]
  },
  {
    "op": "41",
    "offset": 444,
    "value": [
      "u16:6",
      "u8:0",
      "　──もしかすると、それを確かめたかったのかもしれない。"
    ]
  },
  {
    "op": "41",
    "offset": 505,
    "value": [
      "u16:7",
      "u8:0",
      "　それとも──"
    ]
  },
  {
    "op": "41",
    "offset": 524,
    "value": [
      "u16:8",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 535,
    "value": [
      "u16:9",
      "u8:0",
      "　わたしは、２年前の集合写真を眺めた。"
    ]
  },
  {
    "op": "41",
    "offset": 578,
    "value": [
      "u16:10",
      "u8:0",
      "　あの時の切なさ。"
    ]
  },
  {
    "op": "41",
    "offset": 601,
    "value": [
      "u16:11",
      "u8:0",
      "　あの時の苦々しさ。"
    ]
  },
  {
    "op": "41",
    "offset": 626,
    "value": [
      "u16:12",
      "u8:0",
      "　……似てるけど……"
    ]
  },
  {
    "op": "41",
    "offset": 651,
    "value": [
      "u16:13",
      "u8:0",
      "　……似てるけど……違うか……。"
    ]
  },
  {
    "op": "41",
    "offset": 688,
    "value": [
      "u16:14",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 699,
    "value": [
      "u16:15",
      "u8:0",
      "《また少しだったら、付き合ってあげる》"
    ]
  },
  {
    "op": "41",
    "offset": 742,
    "value": [
      "u16:16",
      "u8:0",
      "　……なんで、最後にあんなこと、言っちゃったんだろう。"
    ]
  },
  {
    "op": "41",
    "offset": 801,
    "value": [
      "u16:17",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 812,
    "value": [
      "u16:18",
      "u8:0",
      "　……皮肉だな……。"
    ]
  },
