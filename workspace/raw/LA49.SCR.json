  },
  {
    "op": "41",
    "offset": 3255,
    "value": [
      "u16:52",
      "u8:0",
      "　それから封を切った。"
    ]
  },
  {
    "op": "41",
    "offset": 3282,
    "value": [
      "u16:53",
      "u8:0",
