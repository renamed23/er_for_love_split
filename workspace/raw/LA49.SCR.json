    "op": "42",
    "offset": 7265,
    "value": [
      "u16:121",
      "u8:0",
      "u8:0",
      "ルナ",
      "「うん……。あんなにいい人だったのに……」"
    ]
  },
  {
    "op": "41",
    "offset": 7318,
    "value": [
      "u16:122",
      "u8:0",
      "　ルナも信じられない様子だった。"
    ]
  },
  {
    "op": "49",
    "offset": 7355,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 7359,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 7363,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B003BL"
    ]
  },
  {
