    ]
  },
  {
    "op": "41",
    "offset": 3128,
    "value": [
      "u16:49",
      "u8:0",
      "　きっとルナは着替えているのだろう。"
    ]
  },
  {
    "op": "41",
    "offset": 3169,
    "value": [
      "u16:50",
      "u8:0",
