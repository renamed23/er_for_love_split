    ]
  },
  {
    "op": "42",
    "offset": 7146,
    "value": [
      "u16:119",
      "u8:0",
      "u8:0",
      "ルナ",
      "「そっか……。なんで樹里さん、ふっちゃったんだろう」"
    ]
  },
  {
    "op": "42",
    "offset": 7209,
    "value": [
      "u16:120",
      "u8:0",
      "u8:0",
      "花丸",
      "「やっぱり、結婚かな……」"
    ]
  },
  {
    "op": "23",
