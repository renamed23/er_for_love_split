    "op": "42",
    "offset": 8571,
    "value": [
      "u16:118",
      "u8:0",
      "u8:0",
      "エレナ",
      "「くす。怒ってないわよ」"
    ]
  },
  {
    "op": "41",
    "offset": 8608,
    "value": [
      "u16:119",
      "u8:0",
      "　エレナさんが微笑んだ。"
    ]
  },
  {
    "op": "41",
    "offset": 8637,
    "value": [
      "u16:120",
      "u8:0",
      "　力を失った陽光を海へ放ちながら空と海をオレンジ色に染\\nめていくその瞬間瞬間の変わり具合が、楽しかった。"
    ]
  },
  {
    "op": "23",
    "offset": 8746,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0728.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 8765,
    "value": [
      "u16:121",
      "u8:0",
      "u8:0",
      "エレナ",
      "「花火、行きたいね」"
    ]
  },
  {
    "op": "42",
    "offset": 8798,
    "value": [
      "u16:122",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん」"
    ]
  },
  {
    "op": "23",
    "offset": 8817,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0729.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 8836,
    "value": [
      "u16:123",
      "u8:0",
      "u8:0",
      "エレナ",
      "「わたしの浴衣見たら、もう一度惚れ直すわよ」"
    ]
  },
  {
    "op": "42",
    "offset": 8893,
    "value": [
      "u16:124",
      "u8:0",
      "u8:0",
      "花丸",
      "「欲情したりして」"
    ]
  },
  {
    "op": "23",
    "offset": 8922,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
