    "op": "42",
    "offset": 7437,
    "value": [
      "u16:98",
      "u8:0",
      "u8:0",
      "エレナ",
      "「あっ……ああぁ……あ……花丸くんのが……いっぱい……\\n　あ……ああぁ……」"
    ]
  },
  {
    "op": "41",
    "offset": 7526,
    "value": [
      "u16:99",
      "u8:0",
      "　エレナさんがため息をつく。"
    ]
  },
  {
    "op": "41",
    "offset": 7559,
    "value": [
      "u16:100",
      "u8:0",
      "　おれも、エレナさんの中に深くつながったまま、ため息を\\nついた。"
    ]
  },
