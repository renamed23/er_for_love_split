    "value": [
      "u16:109",
      "u8:0",
      "　夕方、二人。"
    ]
  },
  {
    "op": "41",
    "offset": 8230,
    "value": [
      "u16:110",
      "u8:0",
      "　浜辺に腰を下ろして西の空。"
    ]
  },
  {
    "op": "41",
    "offset": 8263,
    "value": [
      "u16:111",
      "u8:0",
      "　ただ──眺めていた。"
    ]
  },
  {
    "op": "42",
    "offset": 8290,
    "value": [
      "u16:112",
      "u8:0",
      "u8:0",
      "花丸",
      "「また、海行きたいね」"
    ]
  },
  {
    "op": "23",
