    "value": [
      "u16:103",
      "u8:0",
      "u8:0",
      "エレナ",
      "「エッチ。スケベ」"
    ]
  },
  {
    "op": "42",
    "offset": 7816,
    "value": [
      "u16:104",
      "u8:0",
      "u8:0",
      "花丸",
      "「でも、エレナさん、気持ちよかったでしょ？」"
    ]
  },
  {
    "op": "23",
    "offset": 7871,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
