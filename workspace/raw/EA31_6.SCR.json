    "offset": 8342,
    "value": [
      "u16:113",
      "u8:0",
      "u8:0",
      "エレナ",
      "「もうこの水着、着てこないから。花丸くんがエッチになる\\n　から」"
    ]
  },
  {
    "op": "41",
    "offset": 8419,
    "value": [
      "u16:114",
      "u8:0",
      "　思わず笑う。"
    ]
  },
