    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 2943,
    "value": [
      "u16:47",
      "u8:0",
      "　今日も、また雨。"
    ]
  },
  {
    "op": "49",
