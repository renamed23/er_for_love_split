    "offset": 6931,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "B321"
    ]
  },
  {
    "op": "4A",
    "offset": 6946,
    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 6951,
    "value": [
      "u16:122",
      "u8:0",
      "　ずっと、無隣堂で時間を潰していた。"
    ]
  },
  {
    "op": "41",
    "offset": 6992,
    "value": [
      "u16:123",
      "u8:0",
      "　わたし……何やってるんだろう……"
    ]
  },
