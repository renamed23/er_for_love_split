    ]
  },
  {
    "op": "41",
    "offset": 7060,
    "value": [
      "u16:124",
      "u8:0",
      "　金曜日。"
    ]
  },
  {
    "op": "49",
    "offset": 7075,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
