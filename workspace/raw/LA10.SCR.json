    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 6503,
    "value": [
      "u16:114",
      "u8:0",
      "　昼間、寂しくてお兄ちゃんに電話しちゃった。"
    ]
  },
  {
    "op": "41",
    "offset": 6552,
    "value": [
      "u16:115",
      "u8:0",
      "　今日、遊びに来ない？"
    ]
  },
  {
    "op": "41",
    "offset": 6579,
    "value": [
      "u16:116",
      "u8:0",
      "　言おうかと思って、結局言えなかった。"
    ]
  },
  {
    "op": "41",
    "offset": 6622,
    "value": [
      "u16:117",
      "u8:0",
      "　あんまり甘えちゃいけない……"
    ]
  },
  {
    "op": "41",
    "offset": 6657,
    "value": [
      "u16:118",
      "u8:0",
      "　甘え出したら、きっと歯止めが効かなくなっちゃうから。"
    ]
  },
  {
    "op": "41",
    "offset": 6716,
    "value": [
      "u16:119",
      "u8:0",
      "　ママにもパパにも、一人でやれるって言って飛び出したん\\nだもん。"
    ]
  },
  {
    "op": "41",
    "offset": 6785,
    "value": [
      "u16:120",
      "u8:0",
      "　少し寂しいぐらいで甘えてたら……。"
    ]
  },
  {
    "op": "49",
    "offset": 6826,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 6830,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
