    ]
  },
  {
    "op": "42",
    "offset": 3157,
    "value": [
      "u16:47",
      "u8:0",
      "u8:0",
      "エレナ",
      "「花丸くんがオッパイでイクの見るの、好き」"
    ]
  },
  {
    "op": "41",
    "offset": 3212,
    "value": [
      "u16:48",
      "u8:0",
      "　エッチなことを言いながら、たっぷんたっぷんと乳房を波\\n打たせながらおれのものを責め立てる。"
    ]
  },
  {
    "op": "23",
    "offset": 3309,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "ele_0649.ogg"
    ]
  },
