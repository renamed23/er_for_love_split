    "value": [
      "u16:0",
      "u8:0",
      "　ルナと付き合い出して２ヶ月──"
    ]
  },
  {
    "op": "26",
    "offset": 101,
    "value": [
      "u16:0"
    ]
  },
  {
    "op": "25",
    "offset": 104,
    "value": [
      "u8:0",
      "u16:0",
