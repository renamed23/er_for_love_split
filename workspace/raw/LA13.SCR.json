  {
    "op": "42",
    "offset": 1994,
    "value": [
      "u16:29",
      "u8:0",
      "u8:0",
      "ルナ",
      "「ひどいでしょ？」"
    ]
  },
  {
    "op": "42",
    "offset": 2023,
    "value": [
      "u16:30",
      "u8:0",
      "u8:0",
      "花丸",
      "「うん……もう少し数学と英語、がんばんなきゃな」"
    ]
  },
  {
