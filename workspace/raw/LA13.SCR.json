  },
  {
    "op": "42",
    "offset": 740,
    "value": [
      "u16:6",
      "u8:0",
      "u8:0",
      "ルナ",
      "「凄いんだよ～、うちのクラスに全国１位いるんだもん」"
    ]
  },
  {
    "op": "42",
    "offset": 803,
    "value": [
      "u16:7",
      "u8:0",
      "u8:0",
      "花丸",
      "「予備校にはそういう猛者いるよ。なんでこいつ落ちたんだ\\n　ろうってやつ」"
    ]
  },
  {
    "op": "23",
    "offset": 886,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1068.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 905,
    "value": [
      "u16:8",
      "u8:0",
      "u8:0",
      "ルナ",
      "「やっぱ運みたいなの、あるんだね」"
    ]
  },
  {
    "op": "42",
    "offset": 950,
    "value": [
      "u16:9",
      "u8:0",
      "u8:0",
      "花丸",
      "「あるよ。勝負ごとだから」"
    ]
  },
  {
    "op": "23",
    "offset": 987,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
      "lun_1069.ogg"
    ]
  },
  {
    "op": "42",
    "offset": 1006,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "ルナ",
      "「うん。──今、お茶淹れるね」"
    ]
  },
  {
    "op": "49",
    "offset": 1047,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
