    "op": "41",
    "offset": 110,
    "value": [
      "u16:0",
      "u8:0",
      "　家に着いてから、花丸くんと電話でしゃべった。"
    ]
  },
  {
    "op": "41",
    "offset": 161,
    "value": [
      "u16:1",
      "u8:0",
      "　２時間話して切った。"
    ]
  },
  {
    "op": "41",
    "offset": 188,
    "value": [
      "u16:2",
      "u8:0",
      "　切ってからも、なんだか花丸くんがかわいかった。"
    ]
  },
  {
    "op": "41",
    "offset": 241,
    "value": [
      "u16:3",
      "u8:0",
      "　ベッドで気持ちよさそうにしている花丸くんも──。"
    ]
  },
  {
    "op": "41",
    "offset": 296,
    "value": [
      "u16:4",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 307,
    "value": [
      "u16:5",
      "u8:0",
      "　花丸くん。"
    ]
  },
  {
    "op": "41",
    "offset": 324,
    "value": [
      "u16:6",
      "u8:0",
      "　わたしの花丸くん。"
    ]
  },
  {
    "op": "41",
    "offset": 349,
    "value": [
      "u16:7",
      "u8:0",
      "　少し、自由になれた気がする。"
    ]
  },
  {
    "op": "41",
    "offset": 384,
    "value": [
      "u16:8",
      "u8:0",
      "　ずっと、ずっと、心に残っていたセブンテン。"
    ]
  },
  {
    "op": "41",
    "offset": 433,
    "value": [
      "u16:9",
      "u8:0",
      "　それを、花丸くんが取ってくれた。"
    ]
  },
  {
    "op": "41",
    "offset": 472,
    "value": [
      "u16:10",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "49",
    "offset": 483,
    "value": [
      "u8:0",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "49",
    "offset": 487,
    "value": [
      "u8:1",
      "u8:0",
      "u8:0"
    ]
  },
  {
    "op": "46",
    "offset": 491,
    "value": [
      "u16:0",
      "u16:0",
      "u32:0",
      "u8:0",
      "G911"
    ]
  },
  {
    "op": "4A",
    "offset": 506,
    "value": [
      "bytes:19 E8 03 00"
    ]
  },
  {
    "op": "41",
    "offset": 511,
    "value": [
      "u16:11",
      "u8:0",
      "　シェードランプだけつけてベッドに入ってみた。"
    ]
  },
  {
    "op": "41",
    "offset": 562,
    "value": [
      "u16:12",
      "u8:0",
      "　でも──"
    ]
  },
  {
    "op": "41",
    "offset": 577,
    "value": [
      "u16:13",
      "u8:0",
      "　眠れない。"
    ]
  },
  {
    "op": "41",
    "offset": 594,
    "value": [
      "u16:14",
      "u8:0",
      "　花丸くんのことを考えてしまう。"
    ]
  },
  {
    "op": "41",
    "offset": 631,
    "value": [
      "u16:15",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 642,
    "value": [
      "u16:16",
      "u8:0",
      "　花丸くん。"
    ]
  },
  {
    "op": "41",
    "offset": 659,
    "value": [
      "u16:17",
      "u8:0",
      "　もう寝てる？"
    ]
  },
  {
    "op": "41",
    "offset": 678,
    "value": [
      "u16:18",
      "u8:0",
      "　今度、海とか花火とか、色々行こうね。"
    ]
  },
  {
    "op": "41",
    "offset": 721,
    "value": [
      "u16:19",
      "u8:0",
      "　いっしょにクリスマスも、初詣もしようね。"
    ]
  },
