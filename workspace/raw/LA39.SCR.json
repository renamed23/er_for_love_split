    "value": [
      "u16:24",
      "u8:0",
      "u8:0",
      "エレナ",
      "「お熱いことで」"
    ]
  },
  {
    "op": "42",
    "offset": 1532,
    "value": [
      "u16:25",
      "u8:0",
      "u8:0",
      "花丸",
      "「ボウリングはどうなの？　今年もチャンピオン取ったの？」"
    ]
  },
  {
    "op": "23",
    "offset": 1599,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
