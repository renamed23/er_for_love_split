    "value": [
      "u16:22",
      "u8:0",
      "u8:0",
      "エレナ",
      "「今日は行かなくていいの」"
    ]
  },
  {
    "op": "42",
    "offset": 1441,
    "value": [
      "u16:23",
      "u8:0",
      "u8:0",
      "花丸",
      "「ルナのところ？　明日行くから」"
    ]
  },
  {
