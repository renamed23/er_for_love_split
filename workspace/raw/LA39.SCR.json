  {
    "op": "42",
    "offset": 1047,
    "value": [
      "u16:14",
      "u8:0",
      "u8:0",
      "エレナ",
      "「手伝おうか」"
    ]
  },
  {
    "op": "42",
    "offset": 1074,
    "value": [
      "u16:15",
      "u8:0",
      "u8:0",
      "花丸",
      "「いいよ、途中までやったし」"
    ]
  },
  {
