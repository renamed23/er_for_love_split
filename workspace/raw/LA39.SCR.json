  },
  {
    "op": "42",
    "offset": 853,
    "value": [
      "u16:10",
      "u8:0",
      "u8:0",
      "エレナ",
      "「家を間違えてるんじゃなくって？」"
    ]
  },
  {
    "op": "42",
    "offset": 900,
    "value": [
      "u16:11",
      "u8:0",
      "u8:0",
      "花丸",
      "「しばらく見ないうちに美人になったね」"
    ]
  },
  {
    "op": "23",
    "offset": 949,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
