    "value": [
      "u16:20",
      "u8:0",
      "u8:0",
      "エレナ",
      "「つねるわよ」"
    ]
  },
  {
    "op": "41",
    "offset": 1340,
    "value": [
      "u16:21",
      "u8:0",
      "　また無言になって二人で洗い物をする。"
    ]
  },
