    ]
  },
  {
    "op": "42",
    "offset": 968,
    "value": [
      "u16:12",
      "u8:0",
      "u8:0",
      "エレナ",
      "「馬鹿。いつでも美人よ」"
    ]
  },
  {
    "op": "41",
    "offset": 1005,
    "value": [
      "u16:13",
      "u8:0",
      "　少し無言になる。"
    ]
  },
  {
    "op": "23",
    "offset": 1028,
    "value": [
      "u8:0",
      "u16:65535",
      "u16:0",
