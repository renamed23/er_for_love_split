    "op": "41",
    "offset": 1226,
    "value": [
      "u16:18",
      "u8:0",
      "　二人並んで始める。"
    ]
  },
  {
    "op": "42",
    "offset": 1251,
    "value": [
      "u16:19",
      "u8:0",
      "u8:0",
      "花丸",
      "「あ、とか言って手握っていい？」"
    ]
  },
