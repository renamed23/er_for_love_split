  {
    "op": "41",
    "offset": 524,
    "value": [
      "u16:6",
      "u8:0",
      "　１２月２４日、クリスマス前日の朝。"
    ]
  },
  {
    "op": "41",
    "offset": 565,
    "value": [
      "u16:7",
      "u8:0",
      "　ひとり早く目が覚めてしまった。"
    ]
  },
  {
    "op": "41",
    "offset": 602,
    "value": [
      "u16:8",
      "u8:0",
      "　今日はママとパパは二人でホテルにお泊まり。風丸は樹里\\nとクリスマス。そして花丸も……彼女とクリスマス。"
    ]
  },
  {
    "op": "41",
    "offset": 711,
    "value": [
      "u16:9",
      "u8:0",
      "　わたしはひとり。"
    ]
  },
  {
    "op": "41",
    "offset": 734,
    "value": [
      "u16:10",
      "u8:0",
      "　どうして嘘をついちゃったんだろうと思う。"
    ]
  },
  {
    "op": "41",
    "offset": 781,
    "value": [
      "u16:11",
      "u8:0",
      "　もしわたしがひとりだって言ったら、花丸、いっしょに─\\n─"
    ]
  },
  {
    "op": "41",
    "offset": 844,
    "value": [
      "u16:12",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 855,
    "value": [
      "u16:13",
      "u8:0",
      "　馬鹿だな。"
    ]
  },
  {
    "op": "41",
    "offset": 872,
    "value": [
      "u16:14",
      "u8:0",
      "　何考えてるんだろう。"
    ]
  },
  {
    "op": "41",
    "offset": 899,
    "value": [
      "u16:15",
      "u8:0",
      "　……"
    ]
  },
  {
    "op": "41",
    "offset": 910,
    "value": [
      "u16:16",
      "u8:0",
      "　初めて迎える、ひとりきりのクリスマスか。"
    ]
  },
  {
    "op": "41",
    "offset": 957,
    "value": [
      "u16:17",
      "u8:0",
      "　ケーキ、どうしよう。"
    ]
  },
  {
    "op": "41",
    "offset": 984,
    "value": [
      "u16:18",
      "u8:0",
      "　ひとりでキャンドルつけても──"
    ]
  },
  {
    "op": "41",
    "offset": 1021,
    "value": [
      "u16:19",
      "u8:0",
      "　──"
    ]
  },
  {
    "op": "41",
    "offset": 1032,
    "value": [
      "u16:20",
      "u8:0",
      "　どうして、クリスマスなんてあるんだろう……。"
    ]
  },
