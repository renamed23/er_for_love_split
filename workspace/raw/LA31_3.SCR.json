  {
    "op": "42",
    "offset": 1788,
    "value": [
      "u16:32",
      "u8:0",
      "u8:0",
      "エレナ",
      "「下着っ。どうして勝手に洗ったりするのよ」"
    ]
  },
  {
    "op": "42",
    "offset": 1843,
    "value": [
      "u16:33",
      "u8:0",
      "u8:0",
      "花丸",
