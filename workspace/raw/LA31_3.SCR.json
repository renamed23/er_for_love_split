    ]
  },
  {
    "op": "41",
    "offset": 1204,
    "value": [
      "u16:23",
      "u8:0",
      "　返事をしない。いっしょに帰るつもりはないらしい。"
    ]
  },
  {
    "op": "41",
    "offset": 1259,
    "value": [
      "u16:24",
      "u8:0",
      "　まったく、意地っ張りめ。"
    ]
  },
  {
    "op": "41",
    "offset": 1290,
    "value": [
      "u16:25",
      "u8:0",
      "　エレナさんが息をついて歩きだした。"
    ]
  },
