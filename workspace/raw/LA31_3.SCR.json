    ]
  },
  {
    "op": "42",
    "offset": 2298,
    "value": [
      "u16:41",
      "u8:0",
      "u8:0",
      "エレナ",
      "「ちゃんと別々に洗って！　わたしが干すから勝手にしない\\n　で！」"
    ]
  },
  {
    "op": "42",
    "offset": 2375,
    "value": [
      "u16:42",
      "u8:0",
      "u8:0",
      "花丸",
      "「せっかく下着だけでも仲良くしようと思ったのに」"
    ]
  },
